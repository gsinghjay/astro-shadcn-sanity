---
/**
 * Student dashboard — shows team summary, project info, and quick-nav links.
 * Must be SSR — middleware auth populates Astro.locals.user at request time.
 */
import StudentLayout from '@/layouts/StudentLayout.astro';
import { getStudentTeam } from '@/lib/sanity';
import { safeUrlFor } from '@/lib/image';
import { Badge } from '@/components/ui/badge';
import PortalCard from '@/components/portal/PortalCard';

export const prerender = false;

const user = Astro.locals.user;
if (!user?.email) {
  return Astro.redirect('/auth/student-login');
}

const team = await getStudentTeam(user.email);
const displayName = user.name || user.email.split('@')[0];

// Role badge
const roleLabel = team?.isPM ? 'PM' : team?.isAPM ? 'Assistant PM' : 'Member';
const roleBadgeVariant = team?.isPM ? 'default' : team?.isAPM ? 'secondary' : 'outline';

// Sponsor logo (if team has project with sponsor)
const sponsorLogo = team?.project?.sponsor?.logo;
const logoUrl = sponsorLogo ? safeUrlFor(sponsorLogo as Parameters<typeof safeUrlFor>[0])?.width(120).height(120).url() ?? null : null;
const logoLqip = sponsorLogo?.asset?.metadata?.lqip ?? undefined;
---

<StudentLayout title="Student Dashboard" activeNav="/student/" teamName={team?.name ?? undefined}>
  {team ? (
    <div class="flex flex-col gap-8">
      {/* Welcome header with role badge */}
      <div>
        <h1 class="text-2xl font-bold tracking-tight">Welcome back, {displayName}</h1>
        <div class="mt-2 flex items-center gap-2">
          <Badge variant={roleBadgeVariant}>{roleLabel}</Badge>
          <span class="text-sm text-muted-foreground">{team.name} &middot; {team.semester}</span>
        </div>
      </div>

      {/* Dashboard cards grid */}
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {/* Team Summary */}
        <PortalCard
          title="Team Overview"
          description={`${team.memberCount ?? 0}/${team.maxMembers ?? '?'} members`}
          icon="lucide:users"
          href="/student/team"
          disabled={true}
          badge="Coming Soon"
        />

        {/* Project Summary */}
        <PortalCard
          title={team.project?.title ?? 'Project'}
          description={team.project?.sponsor?.name ? `Sponsor: ${team.project.sponsor.name}` : 'No sponsor assigned'}
          icon="lucide:folder"
          href="/student/team"
          disabled={true}
          badge="Coming Soon"
        >
          {logoUrl && (
            <img
              src={logoUrl}
              alt={sponsorLogo?.alt || `${team.project?.sponsor?.name} logo`}
              width="60"
              height="60"
              loading="lazy"
              style={logoLqip ? `background-image: url(${logoLqip}); background-size: cover;` : undefined}
              class="object-contain"
            />
          )}
        </PortalCard>

        {/* Events */}
        <PortalCard
          title="Upcoming Events"
          description="View the program calendar and upcoming events"
          icon="lucide:calendar"
          href="/student/events"
          disabled={true}
          badge="Coming Soon"
        />

        {/* Resources */}
        <PortalCard
          title="Program Resources"
          description="Access guides, templates, and program documentation"
          icon="lucide:book-open"
          href="/student/resources"
          disabled={true}
          badge="Coming Soon"
        />

        {/* PM/APM only: Manage Team */}
        {(team.isPM || team.isAPM) && (
          <PortalCard
            title="Manage Team"
            description="Team settings, member management, and project configuration"
            icon="lucide:wrench"
            href="/student/team"
            disabled={true}
            badge="Coming Soon"
          />
        )}
      </div>

      {/* Quick links (GitHub, Discord) */}
      {(team.githubRepoUrl || team.discordChannelUrl) && (
        <div class="flex flex-wrap gap-4">
          {team.githubRepoUrl && (
            <a
              href={team.githubRepoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"
            >
              <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              <span>GitHub Repository</span>
            </a>
          )}
          {team.discordChannelUrl && (
            <a
              href={team.discordChannelUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"
            >
              <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z" />
              </svg>
              <span>Discord Channel</span>
            </a>
          )}
        </div>
      )}
    </div>
  ) : (
    <div class="flex flex-col gap-8">
      {/* Not assigned to a team — empty state */}
      <div class="flex flex-col items-center justify-center gap-4 py-12 text-center">
        <div class="flex size-16 items-center justify-center bg-muted">
          <svg class="size-8 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <line x1="19" y1="8" x2="19" y2="14" />
            <line x1="22" y1="11" x2="16" y2="11" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight">Not Assigned to a Team Yet</h1>
        <p class="text-muted-foreground max-w-md">
          You'll be assigned to a team by the program administrator. Check back soon or contact your program coordinator.
        </p>
      </div>

      {/* Still show Events and Resources cards */}
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <PortalCard
          title="Upcoming Events"
          description="View the program calendar and upcoming events"
          icon="lucide:calendar"
          href="/student/events"
          disabled={true}
          badge="Coming Soon"
        />
        <PortalCard
          title="Program Resources"
          description="Access guides, templates, and program documentation"
          icon="lucide:book-open"
          href="/student/resources"
          disabled={true}
          badge="Coming Soon"
        />
      </div>
    </div>
  )}
</StudentLayout>

{/* GTM: student dashboard view */}
<script>
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ event: 'student_dashboard_view' });
</script>
