---
export const prerender = true;
import type { GetStaticPaths } from 'astro';
import Layout from '@/layouts/Layout.astro';
import BlockRenderer from '@/components/BlockRenderer.astro';
import SanityPageContent from '@/components/SanityPageContent.astro';
import { sanityClient, ALL_PAGE_SLUGS_QUERY, getPage, getAllSponsors, getAllProjects, getAllTestimonials, getAllEvents, getAllArticles, prefetchPages, getSiteParams } from '@/lib/sanity';
import type { ALL_PAGE_SLUGS_QUERY_RESULT } from '@/sanity.types';
import { urlFor } from '@/lib/image';
import { PUBLIC_SANITY_VISUAL_EDITING_ENABLED } from "astro:env/client";

import FullWidthTemplate from '@/layouts/templates/FullWidthTemplate.astro';

const visualEditingEnabled = PUBLIC_SANITY_VISUAL_EDITING_ENABLED;

// getStaticPaths generates static routes for all published pages at build time
export const getStaticPaths: GetStaticPaths = async () => {
  const pages = await sanityClient.fetch<ALL_PAGE_SLUGS_QUERY_RESULT>(ALL_PAGE_SLUGS_QUERY, getSiteParams());
  // Exclude slugs that have dedicated page routes (e.g., /gallery/index.astro)
  const DEDICATED_ROUTES = new Set(['gallery']);
  const validPages = pages.filter((p): p is { slug: string } => typeof p.slug === 'string' && p.slug.length > 0 && !DEDICATED_ROUTES.has(p.slug));
  // Pre-fetch all pages in parallel batches to populate the cache
  await prefetchPages(validPages.map(p => p.slug));
  return validPages.map((page) => ({
    params: { slug: page.slug },
  }));
};

const { slug } = Astro.params;

// In static mode: fetch page data and render inline
// In VE mode: skip fetch — server island handles its own data fetching
let page = null;
let sponsors: Awaited<ReturnType<typeof getAllSponsors>> = [];
let projects: Awaited<ReturnType<typeof getAllProjects>> = [];
let testimonials: Awaited<ReturnType<typeof getAllTestimonials>> = [];
let events: Awaited<ReturnType<typeof getAllEvents>> = [];
let articles: Awaited<ReturnType<typeof getAllArticles>> = [];

if (!visualEditingEnabled) {
  page = await getPage(slug as string);
  if (!page) {
    return Astro.redirect('/404');
  }
  sponsors = await getAllSponsors();
  projects = await getAllProjects();
  testimonials = await getAllTestimonials();
  events = await getAllEvents();
  articles = await getAllArticles();
}

// Extract first hero image for <link rel="preload"> (LCP optimization)
const firstBlock = page?.blocks?.[0];
const heroImage = firstBlock?._type === 'heroBanner'
  ? (firstBlock as { backgroundImages?: Array<{ asset?: { _id: string } | null }> }).backgroundImages?.[0]
  : null;
const preloadImageUrl = heroImage?.asset
  ? urlFor(heroImage).width(1920).height(1080).fit('crop').url()
  : undefined;
const preloadSrcset = heroImage?.asset
  ? [640, 1024, 1440, 1920].map(w => `${urlFor(heroImage).width(w).height(Math.round(w * 1080 / 1920)).fit('crop').url()} ${w}w`).join(', ')
  : undefined;
---

<Layout
  title={page?.title ?? undefined}
  seo={page?.seo}
  preloadImage={preloadImageUrl}
  preloadImageSrcset={preloadSrcset}
  preloadImageSizes="100vw"
>
  {visualEditingEnabled ? (
    <SanityPageContent server:defer slug={slug as string}>
      <div slot="fallback" class="mx-auto max-w-(--grid-max-width) px-(--grid-margin) py-12">
        <div class="animate-pulse space-y-8">
          <div class="h-10 bg-muted rounded w-2/5"></div>
          <div class="h-64 bg-muted rounded"></div>
          <div class="space-y-3">
            <div class="h-4 bg-muted rounded w-3/4"></div>
            <div class="h-4 bg-muted rounded w-1/2"></div>
          </div>
        </div>
      </div>
    </SanityPageContent>
  ) : (
    <FullWidthTemplate>
      <BlockRenderer blocks={page!.blocks ?? []} sponsors={sponsors} projects={projects} testimonials={testimonials} events={events} articles={articles} />
    </FullWidthTemplate>
  )}
</Layout>
