---
import Layout from '@/layouts/Layout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import BlockRenderer from '@/components/BlockRenderer.astro';
import { getAllSponsors, getListingPage } from '@/lib/sanity';
import { Section, SectionContent, SectionGrid } from '@/components/ui/section';
import SponsorCard from '@/components/SponsorCard.astro';
import { buildBreadcrumbJsonLd } from '@/lib/breadcrumb-jsonld';
import { buildPageGraph } from '@/lib/page-jsonld';
import { buildOrgJsonLd } from '@/lib/org-jsonld';

const [sponsors, listingPage] = await Promise.all([
  getAllSponsors(),
  getListingPage('sponsors'),
]);

const pageTitle = listingPage?.title ?? 'Sponsors';
const pageH1 = listingPage?.title ?? 'Our Sponsors';
const pageDescription = listingPage?.description ?? null;
const pageSeo = listingPage?.seo ?? { metaDescription: 'Meet the industry sponsors partnering with YWCC to provide real-world capstone project experiences for students.' };

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: pageTitle },
];
const breadcrumbJsonLd = buildBreadcrumbJsonLd(breadcrumbItems, Astro.url.origin, Astro.url.pathname);
const orgJsonLd = await buildOrgJsonLd(Astro.url.origin);
const pageGraph = buildPageGraph(orgJsonLd, breadcrumbJsonLd);
---

<Layout title={pageTitle} seo={pageSeo}>
  <script slot="structured-data" type="application/ld+json" set:html={JSON.stringify(pageGraph)} />
  {listingPage?.headerBlocks && listingPage.headerBlocks.length > 0 && (
    <BlockRenderer blocks={listingPage.headerBlocks} />
  )}

  <Section>
    <SectionContent>
      <Breadcrumb items={breadcrumbItems} />

      <h1 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{pageH1}</h1>
      {pageDescription && (
        <p class="text-lg text-muted-foreground">{pageDescription}</p>
      )}
    </SectionContent>

    <SectionGrid size="lg">
      {sponsors.map((sponsor) => (
        <SponsorCard sponsor={sponsor} />
      ))}
    </SectionGrid>
  </Section>

  {listingPage?.footerBlocks && listingPage.footerBlocks.length > 0 && (
    <BlockRenderer blocks={listingPage.footerBlocks} />
  )}
</Layout>
