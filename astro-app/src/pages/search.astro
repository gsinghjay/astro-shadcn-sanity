---
/*
 * /search — Dedicated search results page (Story 5.23 redesign).
 *
 * Replaces the Story 5.15 vendor `<search-bar-snippet>` (Shadow DOM) with a
 * headless React island driven by `AISearchClient` from `@cloudflare/ai-search-snippet`.
 * Results render as native `<ol>` / `<li>` HTML in the page light DOM so
 * Playwright/locator + crawlers + screen readers reach them directly.
 *
 * Marked noIndex via Layout's SEO prop — also excluded from sitemap (astro.config.mjs)
 * and `Disallow: /search` in robots.txt.ts.
 */
import Layout from "@/layouts/Layout.astro";
import { Section, SectionContent } from "@/components/ui/section";
import SearchResults from "@/components/react/SearchResults";
import { getSiteSettings } from "@/lib/sanity";
import { stegaClean } from "@sanity/client/stega";

const settings = await getSiteSettings();
const aiSearch = settings.aiSearch;

// Mirror SearchModal.astro's URL allowlist (Story 5.15 P3): https only,
// no embedded credentials, normalized to origin + pathname.
const rawApiUrl = stegaClean(aiSearch?.apiUrl ?? "").trim();
const cleanApiUrl = (() => {
  if (!rawApiUrl) return "";
  try {
    const u = new URL(rawApiUrl);
    if (u.protocol !== "https:") return "";
    if (u.username || u.password) return "";
    return u.origin + u.pathname;
  } catch {
    return "";
  }
})();
const cleanPlaceholder = stegaClean(aiSearch?.placeholder ?? "Search the site…").trim();

// Guard mirrors Header.astro: searchModalEnabled true AND apiUrl validates.
const searchAvailable = Boolean(aiSearch?.searchModalEnabled && cleanApiUrl);

// Initial query is read server-side so the React island can run the first
// fetch on mount without a perceptual delay. Query NOT passed to the
// disabled-state panel (no leakage when feature is off).
const initialQuery = (Astro.url.searchParams.get("q") ?? "").trim().slice(0, 256);
---

<Layout title="Search" seo={{ noIndex: true }}>
  <Section>
    <SectionContent>
      <h1 class="label-caps mb-8">Search</h1>

      {!searchAvailable ? (
        <div class="border-2 border-foreground bg-secondary p-6 text-center">
          <p class="text-foreground mb-4">
            Search is currently unavailable. Please try again later.
          </p>
          <p class="text-foreground text-sm">
            In the meantime, you can <a href="/" class="underline-offset-4 hover:underline font-bold">browse the homepage</a>
            {" "}or jump to <a href="/articles" class="underline-offset-4 hover:underline font-bold">articles</a>,
            {" "}<a href="/events" class="underline-offset-4 hover:underline font-bold">events</a>,
            {" "}<a href="/projects" class="underline-offset-4 hover:underline font-bold">projects</a>,
            {" "}or <a href="/sponsors" class="underline-offset-4 hover:underline font-bold">sponsors</a>.
          </p>
        </div>
      ) : (
        <SearchResults
          client:only="react"
          apiUrl={cleanApiUrl}
          initialQuery={initialQuery}
          placeholder={cleanPlaceholder}
        />
      )}
    </SectionContent>
  </Section>
</Layout>
