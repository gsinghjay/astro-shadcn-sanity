---
export const prerender = true;
import SidebarLayout from '@/layouts/SidebarLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import BlockRenderer from '@/components/BlockRenderer.astro';
import { getAllProjects, getListingPage } from '@/lib/sanity';
import { stegaClean } from '@sanity/client/stega';
import { Section, SectionContent } from '@/components/ui/section';
import ProjectCardEnhanced from '@/components/ProjectCardEnhanced.astro';
import ProjectFilterBar from '@/components/ProjectFilterBar.astro';
import { buildBreadcrumbJsonLd } from '@/lib/breadcrumb-jsonld';
import { buildPageGraph } from '@/lib/page-jsonld';
import { buildOrgJsonLd } from '@/lib/org-jsonld';
import ProjectPageHeader from '@/components/ProjectPageHeader.astro';
import ProjectEmptyState from '@/components/ProjectEmptyState.astro';

const [projects, listingPage] = await Promise.all([
  getAllProjects(),
  getListingPage('projects'),
]);
const allTechs = [...new Set(projects.flatMap(p => (p.technologyTags ?? []).map(t => stegaClean(t))))].sort();
const allIndustries = [...new Set(projects.map(p => p.sponsor?.industry ? stegaClean(p.sponsor.industry) : '').filter(Boolean))].sort();

const pageTitle = listingPage?.title ?? 'Projects';
const pageH1 = listingPage?.title ?? 'Capstone Projects';
const pageDescription = listingPage?.description ?? null;
const pageSeo = listingPage?.seo ?? { metaDescription: 'Explore capstone projects where YWCC students solve real industry problems with sponsor organizations.' };

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: pageTitle },
];
const breadcrumbJsonLd = buildBreadcrumbJsonLd(breadcrumbItems, Astro.url.origin, Astro.url.pathname);
const orgJsonLd = await buildOrgJsonLd(Astro.url.origin);
const pageGraph = buildPageGraph(orgJsonLd, breadcrumbJsonLd);
---

<SidebarLayout title={pageTitle} seo={pageSeo}>
  <script slot="structured-data" type="application/ld+json" set:html={JSON.stringify(pageGraph)} />
  {listingPage?.headerBlocks && listingPage.headerBlocks.length > 0 && (
    <BlockRenderer blocks={listingPage.headerBlocks} slot="header" />
  )}

  <Section slot="header">
    <SectionContent>
      <Breadcrumb items={breadcrumbItems} />

      <ProjectPageHeader
        title={pageH1}
        description={pageDescription}
        projects={projects}
      />
    </SectionContent>
  </Section>

  <div class="grid grid-cols-1 @2xl:grid-cols-2 gap-6">
    {projects.map((project) => (
      <ProjectCardEnhanced project={project} />
    ))}
  </div>

  {/* Empty state — hidden by default, shown by filter JS */}
  <div class="hidden" data-empty-state-wrap>
    <ProjectEmptyState variant="filtered" />
  </div>

  <ProjectFilterBar
    slot="sidebar"
    techs={allTechs}
    industries={allIndustries}
  />

  {listingPage?.footerBlocks && listingPage.footerBlocks.length > 0 && (
    <BlockRenderer blocks={listingPage.footerBlocks} slot="footer" />
  )}
</SidebarLayout>

<style is:global>
  [data-project-card][data-state="hidden"] { display: none; }
</style>

<script>
  function initProjectFilter(): void {
    const container = document.querySelector('[data-project-filters]');
    if (!container) return;

    const cards = document.querySelectorAll<HTMLElement>('[data-project-card]');
    const emptyWrap = document.querySelector<HTMLElement>('[data-empty-state-wrap]');
    const clearFilterBtns = document.querySelectorAll<HTMLElement>('[data-clear-filters]');
    const clearFiltersWrap = container.querySelector<HTMLElement>('[data-clear-filters-wrap]');
    const sortSelect = container.querySelector<HTMLSelectElement>('[data-project-sort]');
    let activeTech = 'all';
    let activeIndustry = 'all';
    let activeSort = 'newest';

    function applySorting() {
      const parent = cards[0]?.parentElement;
      if (!parent) return;

      const visible: HTMLElement[] = [];
      const hidden: HTMLElement[] = [];
      cards.forEach((el) => {
        if (el.dataset.state === 'hidden') {
          hidden.push(el);
        } else {
          visible.push(el);
        }
      });

      visible.sort((a, b) => {
        switch (activeSort) {
          case 'newest':
            return (b.dataset.sortDate ?? '').localeCompare(a.dataset.sortDate ?? '');
          case 'oldest':
            return (a.dataset.sortDate ?? '').localeCompare(b.dataset.sortDate ?? '');
          case 'title-asc':
            return (a.dataset.sortTitle ?? '').localeCompare(b.dataset.sortTitle ?? '');
          case 'title-desc':
            return (b.dataset.sortTitle ?? '').localeCompare(a.dataset.sortTitle ?? '');
          default:
            return 0;
        }
      });

      visible.forEach((el) => parent.appendChild(el));
    }

    function applyFilters() {
      let visibleCount = 0;
      cards.forEach((el) => {
        const techs = el.dataset.techTags?.split(',').filter(Boolean) ?? [];
        const industry = el.dataset.industry ?? '';

        const matchesTech = activeTech === 'all' || techs.includes(activeTech);
        const matchesIndustry = activeIndustry === 'all' || industry === activeIndustry;
        const visible = matchesTech && matchesIndustry;

        el.dataset.state = visible ? 'visible' : 'hidden';
        if (visible) visibleCount++;
      });

      // Toggle empty state
      if (emptyWrap) {
        emptyWrap.classList.toggle('hidden', visibleCount > 0);
      }

      // Toggle clear-all button
      const hasActiveFilters = activeTech !== 'all' || activeIndustry !== 'all';
      if (clearFiltersWrap) {
        clearFiltersWrap.classList.toggle('hidden', !hasActiveFilters);
      }

      applySorting();
    }

    function resetFilters() {
      activeTech = 'all';
      activeIndustry = 'all';

      container.querySelectorAll<HTMLElement>('[data-filter-tech]').forEach(b => {
        const isAll = b.dataset.filterTech === 'all';
        b.setAttribute('aria-pressed', isAll ? 'true' : 'false');
        b.dataset.state = isAll ? 'active' : '';
      });

      container.querySelectorAll<HTMLElement>('[data-filter-industry]').forEach(b => {
        const isAll = b.dataset.filterIndustry === 'all';
        b.setAttribute('aria-pressed', isAll ? 'true' : 'false');
        b.dataset.state = isAll ? 'active' : '';
      });

      applyFilters();
    }

    // Sort dropdown change event
    if (sortSelect) {
      sortSelect.addEventListener('change', () => {
        activeSort = sortSelect.value;
        applySorting();
      });
    }

    container.querySelectorAll<HTMLElement>('[data-filter-tech]').forEach(btn => {
      btn.addEventListener('click', () => {
        activeTech = btn.dataset.filterTech ?? 'all';
        container.querySelectorAll<HTMLElement>('[data-filter-tech]').forEach(b => {
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
          b.dataset.state = b === btn ? 'active' : '';
        });
        applyFilters();
      });
    });

    container.querySelectorAll<HTMLElement>('[data-filter-industry]').forEach(btn => {
      btn.addEventListener('click', () => {
        activeIndustry = btn.dataset.filterIndustry ?? 'all';
        container.querySelectorAll<HTMLElement>('[data-filter-industry]').forEach(b => {
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
          b.dataset.state = b === btn ? 'active' : '';
        });
        applyFilters();
      });
    });

    // Clear-all buttons (sidebar + empty state)
    clearFilterBtns.forEach(btn => {
      btn.addEventListener('click', resetFilters);
    });

    // Apply default "Newest First" sort on page load
    applyFilters();
  }

  initProjectFilter();
</script>
