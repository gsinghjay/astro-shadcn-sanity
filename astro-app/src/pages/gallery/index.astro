---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import GalleryGrid from '@/components/blocks/custom/_partials/GalleryGrid.astro';
import BlockRenderer from '@/components/BlockRenderer.astro';
import { Section, SectionContent } from '@/components/ui/section';
import { getListingPage, getGalleryAssets } from '@/lib/sanity';
import { buildBreadcrumbJsonLd } from '@/lib/breadcrumb-jsonld';
import { buildPageGraph } from '@/lib/page-jsonld';
import { buildOrgJsonLd } from '@/lib/org-jsonld';
import JsonLd from '@/components/ui/json-ld/JsonLd.astro';

const [listingPage, galleryItems] = await Promise.all([
  getListingPage('gallery'),
  getGalleryAssets(),
]);

const pageTitle = listingPage?.title ?? 'Gallery';
const pageDescription = listingPage?.description ?? null;
const pageSeo = listingPage?.seo ?? { metaDescription: 'Browse photos from the YWCC Industry Capstone program.' };

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: pageTitle },
];
const breadcrumbJsonLd = buildBreadcrumbJsonLd(breadcrumbItems, Astro.url.origin, Astro.url.pathname);
const orgJsonLd = await buildOrgJsonLd(Astro.url.origin);
const pageGraph = buildPageGraph(orgJsonLd, breadcrumbJsonLd);
---

<Layout title={pageTitle} seo={pageSeo}>
  <JsonLd schema={pageGraph} slot="structured-data" />
  {listingPage?.headerBlocks && listingPage.headerBlocks.length > 0 && (
    <BlockRenderer blocks={listingPage.headerBlocks} />
  )}

  <Section>
    <SectionContent>
      <Breadcrumb items={breadcrumbItems} />

      {galleryItems.length > 0 ? (
        <GalleryGrid
          items={galleryItems}
          variant="grid"
          heading={pageTitle}
          description={pageDescription}
          bare
          idSuffix="gallery-listing"
        />
      ) : (
        <p class="text-muted-foreground">No gallery photos yet. Check back soon.</p>
      )}
    </SectionContent>
  </Section>

  {listingPage?.footerBlocks && listingPage.footerBlocks.length > 0 && (
    <BlockRenderer blocks={listingPage.footerBlocks} />
  )}
</Layout>
