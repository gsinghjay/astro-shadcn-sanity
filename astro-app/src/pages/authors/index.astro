---
import Layout from '@/layouts/Layout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import AuthorCard from '@/components/AuthorCard.astro';
import { Section, SectionContent, SectionGrid } from '@/components/ui/section';
import { getAllAuthors } from '@/lib/sanity';

const authors = await getAllAuthors();
---

<Layout title="Authors" seo={{ metaDescription: 'Meet the authors behind our articles and learn about their expertise and background.' }}>
  <Section>
    <SectionContent>
      <Breadcrumb baseUrl={Astro.url.origin} items={[
        { label: 'Home', href: '/' },
        { label: 'Authors' },
      ]} />

      <h1 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">Authors</h1>
    </SectionContent>

    {authors.length > 0 ? (
      <SectionGrid size="lg">
        {authors.map((author) => (
          <AuthorCard author={author} />
        ))}
      </SectionGrid>
    ) : (
      <SectionContent>
        <p class="text-muted-foreground text-center py-8">No authors to display.</p>
      </SectionContent>
    )}
  </Section>
</Layout>
