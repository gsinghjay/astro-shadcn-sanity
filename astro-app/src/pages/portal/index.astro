---
export const prerender = false;

import PortalLayout from "@/layouts/PortalLayout.astro";
import PortalCard from "@/components/portal/PortalCard";
import PortalSkeleton from "@/components/portal/PortalSkeleton";
import BlockRenderer from "@/components/BlockRenderer.astro";
import { loadQuery, SPONSOR_BY_EMAIL_QUERY, getSiteParams, getPortalPage } from "@/lib/sanity";
import { stegaClean } from "@sanity/client/stega";
import type { SPONSOR_BY_EMAIL_QUERY_RESULT } from "@/sanity.types";

const user = Astro.locals.user;

// Look up sponsor by email to enable "My Projects" card link
const { result: sponsor } = await loadQuery<SPONSOR_BY_EMAIL_QUERY_RESULT>({
  query: SPONSOR_BY_EMAIL_QUERY,
  params: { email: user?.email ?? '', ...getSiteParams() },
});

const portalPage = await getPortalPage('dashboard');
const pageTitle = portalPage?.title ?? 'Welcome to the Sponsor Portal';

const defaultCards = [
  {
    title: "My Projects",
    description: "View your sponsored capstone projects, student teams, and technologies used",
    icon: "lucide:folder",
    href: sponsor?.slug ? `/portal/${sponsor.slug}` : undefined,
    disabled: !sponsor?.slug,
  },
  {
    title: "Project Progress",
    description: "Connect your GitHub repos and track issues, PRs, releases, and development activity",
    icon: "lucide:git-pull-request",
    href: "/portal/progress",
  },
  {
    title: "Events & Schedule",
    description: "View the interactive calendar of showcases, workshops, and networking events",
    icon: "lucide:calendar",
    href: "/portal/events",
  },
  {
    title: "My Sponsorship",
    description: "Sponsorship tier, agreements, expectations, and program contact information",
    icon: "lucide:handshake",
    href: "/portal/sponsorship",
  },
];

const cards = (portalPage?.dashboardCards && portalPage.dashboardCards.length > 0)
  ? portalPage.dashboardCards.map((card) => {
      const cleanRoute = (stegaClean(card.route) ?? '').trim();
      const cleanIcon = stegaClean(card.iconName)?.trim();
      const needsSlug = cleanRoute.includes('{sponsorSlug}');
      const hasSlug = Boolean(sponsor?.slug);
      const resolvedHref = needsSlug
        ? cleanRoute.replaceAll('{sponsorSlug}', sponsor?.slug ?? '')
        : cleanRoute;
      const disabled = card.enabled === false || !resolvedHref || (needsSlug && !hasSlug);
      return {
        title: card.title ?? '',
        description: card.description ?? '',
        icon: cleanIcon ? `lucide:${cleanIcon}` : 'lucide:file',
        href: disabled ? undefined : resolvedHref,
        disabled,
      };
    })
  : defaultCards;
---

<PortalLayout title="Sponsor Portal" activeNav="/portal/" sponsorSlug={sponsor?.slug}>
  <div class="flex flex-col gap-8">
    {portalPage?.headerBlocks && portalPage.headerBlocks.length > 0 && (
      <BlockRenderer blocks={portalPage.headerBlocks} />
    )}

    {/* Welcome heading */}
    <div class="flex flex-col gap-2">
      <h1 class="text-2xl font-bold tracking-tight">{pageTitle}</h1>
      <p class="text-muted-foreground">
        Signed in as <strong>{user?.email ?? "unknown"}</strong>
      </p>
    </div>

    {/* Skeleton placeholder cards — no client directive, SSR-only */}
    <div class="grid gap-6 sm:grid-cols-2">
      {cards.map((card) => (
        <PortalCard
          title={card.title}
          description={card.description}
          icon={card.icon}
          href={card.href}
          disabled={card.disabled}
          badge={card.disabled ? "Coming Soon" : undefined}
        >
          {card.disabled && <PortalSkeleton lines={2} />}
        </PortalCard>
      ))}
    </div>

    {portalPage?.footerBlocks && portalPage.footerBlocks.length > 0 && (
      <BlockRenderer blocks={portalPage.footerBlocks} />
    )}
  </div>
</PortalLayout>

{/* GTM: portal landing page view — only pushes if consent accepted */}
<script>
  try {
    if (localStorage.getItem('cookie-consent') === 'accepted') {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: "portal_landing_view" });
    }
  } catch { /* localStorage unavailable */ }
</script>
