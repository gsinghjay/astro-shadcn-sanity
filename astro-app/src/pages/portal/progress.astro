---
export const prerender = false;

import PortalLayout from '@/layouts/PortalLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import BlockRenderer from '@/components/BlockRenderer.astro';
import { buildBreadcrumbJsonLd } from '@/lib/breadcrumb-jsonld';
import { buildPageGraph } from '@/lib/page-jsonld';
import GitHubDashboard from '@/components/portal/GitHubDashboard';
import RepoLinker from '@/components/portal/RepoLinker';
import { getDrizzle } from '@/lib/db';
import { getGitHubToken, getAllGitHubData, parseGitHubRepo } from '@/lib/github';
import type {
  RepoOverview,
  GitHubIssue,
  GitHubPullRequest,
  GitHubRelease,
  GitHubCommitActivity,
  GitHubContributor,
  GitHubWorkflowRun,
  GitHubCommit,
  GitHubLanguages,
} from '@/lib/github';
import { stegaClean } from '@sanity/client/stega';
import { projectGithubRepos } from '@/lib/drizzle-schema';
import { eq } from 'drizzle-orm';
import {
  loadQuery,
  SPONSOR_BY_EMAIL_QUERY,
  getSiteParams,
  getSponsorProjects,
  getPortalPage,
} from '@/lib/sanity';
import type { SPONSOR_BY_EMAIL_QUERY_RESULT } from '@/sanity.types';

const user = Astro.locals.user;
const email = user?.email ?? '';

// Sponsor lookup for sidebar nav
const { result: sponsor } = await loadQuery<SPONSOR_BY_EMAIL_QUERY_RESULT>({
  query: SPONSOR_BY_EMAIL_QUERY,
  params: { email, ...getSiteParams() },
});

// Get GitHub token from D1
const db = getDrizzle();
const tokenResult = await getGitHubToken(db, email);

// State machine: determine page state
const state = tokenResult.error
  ? tokenResult.error
  : 'has-token';

// Fetch data only when we have a valid token
let projects: Awaited<ReturnType<typeof getSponsorProjects>> = [];
let links: typeof projectGithubReposRows = [];
let linkedProjectsData: Array<{
  projectTitle: string;
  githubRepo: string;
  overview: RepoOverview | null;
  issues: GitHubIssue[] | null;
  pullRequests: { open: GitHubPullRequest[]; recentlyMerged: GitHubPullRequest[] } | null;
  releases: GitHubRelease[] | null;
  commitActivity: GitHubCommitActivity[] | null;
  contributors: GitHubContributor[] | null;
  workflowRuns: GitHubWorkflowRun[] | null;
  recentCommits: GitHubCommit[] | null;
  languages: GitHubLanguages | null;
  errors: Record<string, string | undefined>;
}> = [];
let unlinkedProjects: typeof projects = [];

type ProjectGithubRepoRow = {
  id: string;
  userEmail: string;
  projectSanityId: string;
  githubRepo: string;
  linkedAt: Date;
};
let projectGithubReposRows: ProjectGithubRepoRow[] = [];

if (state === 'has-token') {
  // Fetch sponsor's projects + existing repo links in parallel
  const [projectsResult, linksResult] = await Promise.all([
    getSponsorProjects(email),
    db
      .select()
      .from(projectGithubRepos)
      .where(eq(projectGithubRepos.userEmail, email))
      .all(),
  ]);

  projects = projectsResult;
  projectGithubReposRows = linksResult;

  // Build link map: projectSanityId -> githubRepo
  const linkMap = new Map(
    projectGithubReposRows.map(l => [l.projectSanityId, l.githubRepo]),
  );

  // Separate linked vs unlinked
  const linked = projects.filter(p => linkMap.has(p._id));
  unlinkedProjects = projects.filter(p => !linkMap.has(p._id));

  // Fetch GitHub data for all linked projects in parallel
  if (linked.length > 0 && tokenResult.token) {
    const githubResults = await Promise.all(
      linked.map(async project => {
        const repo = linkMap.get(project._id)!;
        const { owner, repo: repoName } = parseGitHubRepo(repo);
        const data = await getAllGitHubData({
          token: tokenResult.token!,
          owner,
          repo: repoName,
        });

        return {
          projectTitle: stegaClean(project.title) ?? 'Untitled',
          githubRepo: repo,
          overview: data.overview.data,
          issues: data.issues.data,
          pullRequests: data.pullRequests.data,
          releases: data.releases.data,
          commitActivity: data.commitActivity.data,
          contributors: data.contributors.data,
          workflowRuns: data.workflowRuns.data,
          recentCommits: data.recentCommits.data,
          languages: data.languages.data,
          errors: {
            overview: data.overview.error ?? undefined,
            issues: data.issues.error ?? undefined,
            pullRequests: data.pullRequests.error ?? undefined,
            releases: data.releases.error ?? undefined,
            commitActivity: data.commitActivity.error ?? undefined,
            contributors: data.contributors.error ?? undefined,
            workflowRuns: data.workflowRuns.error ?? undefined,
            recentCommits: data.recentCommits.error ?? undefined,
            languages: data.languages.error ?? undefined,
          },
        };
      }),
    );

    linkedProjectsData = githubResults;
  }

  links = projectGithubReposRows;
}

// Serialize links for RepoLinker (Date -> string)
const serializedLinks = links.map(l => ({
  ...l,
  linkedAt: l.linkedAt instanceof Date ? l.linkedAt.toISOString() : String(l.linkedAt),
}));

const portalPage = await getPortalPage('progress');
const pageTitle = portalPage?.title ?? 'Project Progress';
const pageDescription = portalPage?.description ?? 'Track development activity for your sponsored projects via GitHub.';

const breadcrumbItems = [
  { label: 'Portal', href: '/portal/' },
  { label: stegaClean(pageTitle) ?? pageTitle },
];
const breadcrumbJsonLd = buildBreadcrumbJsonLd(breadcrumbItems, Astro.url.origin, Astro.url.pathname);
const pageGraph = buildPageGraph(breadcrumbJsonLd);
---

<PortalLayout title={pageTitle} activeNav="/portal/progress" sponsorSlug={sponsor?.slug}>
  <script slot="structured-data" type="application/ld+json" set:html={JSON.stringify(pageGraph)} />
  <div class="flex flex-col gap-6">
    <Breadcrumb items={breadcrumbItems} />

    {portalPage?.headerBlocks && portalPage.headerBlocks.length > 0 && (
      <BlockRenderer blocks={portalPage.headerBlocks} />
    )}

    <div class="flex flex-col gap-2">
      <h1 class="text-2xl font-bold tracking-tight">{pageTitle}</h1>
      {pageDescription && (
        <p class="text-muted-foreground">{pageDescription}</p>
      )}
    </div>

    {/* State: no GitHub account linked */}
    {state === 'no-github-account' && (
      <div class="border bg-card p-6 flex flex-col gap-4 items-start">
        <h2 class="text-lg font-semibold">Connect your GitHub account</h2>
        <p class="text-sm text-muted-foreground">
          Link your GitHub account to view development progress for your projects.
          This will allow us to access your repositories securely.
        </p>
        <button
          id="connect-github"
          type="button"
          class="bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90"
        >
          Connect GitHub
        </button>
      </div>
    )}

    {/* State: missing repo scope */}
    {state === 'missing-scope' && (
      <div class="border bg-card p-6 flex flex-col gap-4 items-start">
        <h2 class="text-lg font-semibold">Re-authorize GitHub</h2>
        <p class="text-sm text-muted-foreground">
          Your GitHub connection needs additional permissions to access repository data.
          Please re-authorize to grant the required scope.
        </p>
        <button
          id="reauth-github"
          type="button"
          class="bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90"
        >
          Re-authorize GitHub
        </button>
      </div>
    )}

    {/* State: GitHub token expired */}
    {state === 'token-expired' && (
      <div class="border bg-card p-6 flex flex-col gap-4 items-start">
        <h2 class="text-lg font-semibold">GitHub session expired</h2>
        <p class="text-sm text-muted-foreground">
          Your GitHub access token has expired. Please re-authenticate to restore access
          to your repository data.
        </p>
        <button
          id="reauth-github"
          type="button"
          class="bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90"
        >
          Re-authenticate GitHub
        </button>
      </div>
    )}

    {/* State: has token but no projects */}
    {state === 'has-token' && projects.length === 0 && (
      <div class="border bg-card p-6 flex flex-col gap-4 items-center text-center">
        <p class="text-muted-foreground">
          No projects found for your account. Projects are assigned in the content management system.
        </p>
      </div>
    )}

    {/* State: has token and projects */}
    {state === 'has-token' && projects.length > 0 && (
      <>
        {/* Dashboard for linked projects */}
        {linkedProjectsData.length > 0 && (
          <GitHubDashboard client:load projects={linkedProjectsData} />
        )}

        {/* Repo linker for all projects — link unlinked, change/unlink linked */}
        <RepoLinker
          client:load
          projects={projects}
          links={serializedLinks}
          linkEndpoint="/portal/api/github/links"
          reposEndpoint="/portal/api/github/repos"
        />
      </>
    )}

    {portalPage?.footerBlocks && portalPage.footerBlocks.length > 0 && (
      <BlockRenderer blocks={portalPage.footerBlocks} />
    )}
  </div>
</PortalLayout>

{/* Client-side scripts for GitHub OAuth connection */}
<script>
  import { authClient } from '@/lib/auth-client';

  // Link GitHub (new connection — user has no GitHub account linked)
  document.getElementById('connect-github')?.addEventListener('click', () => {
    authClient.linkSocial({
      provider: 'github',
      callbackURL: '/portal/progress',
    });
  });

  // Re-authorize GitHub (existing connection — token expired or missing scope)
  // Uses signIn.social to re-trigger OAuth flow and update stored token/scope
  document.getElementById('reauth-github')?.addEventListener('click', () => {
    authClient.signIn.social({
      provider: 'github',
      callbackURL: '/portal/progress',
    });
  });
</script>
