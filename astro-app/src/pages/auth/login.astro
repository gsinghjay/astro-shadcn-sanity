---
/**
 * Student sign-in page — auto-triggers Google OAuth via Better Auth client.
 * Located outside /student/* to avoid middleware auth redirect loop.
 * Accepts ?redirect= query parameter for post-login navigation.
 * Must be SSR since it depends on client-side auth flow at runtime.
 */
export const prerender = false;

const redirect = Astro.url.searchParams.get('redirect') || '/student/';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Student Sign In</title>
  </head>
  <body data-redirect={redirect}>
    <p>Redirecting to Google sign-in...</p>
    <script>
      import { createAuthClient } from "better-auth/client";

      const authClient = createAuthClient({
        baseURL: window.location.origin + "/api/auth",
      });

      const serverRedirect = document.body.getAttribute('data-redirect') || '/student/';
      const redirectParam = new URLSearchParams(window.location.search).get('redirect') || serverRedirect;

      authClient.signIn.social({
        provider: "google",
        callbackURL: redirectParam,
      });
    </script>
  </body>
</html>
