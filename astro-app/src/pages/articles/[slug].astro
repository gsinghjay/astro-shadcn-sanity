---
import type { GetStaticPaths } from 'astro';
import Layout from '@/layouts/Layout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import {
  sanityClient,
  ALL_ARTICLE_SLUGS_QUERY,
  getArticleBySlug,
  getSiteParams,
  getSiteSettings,
} from '@/lib/sanity';
import type { ALL_ARTICLE_SLUGS_QUERY_RESULT } from '@/sanity.types';
import { safeUrlFor } from '@/lib/image';
import { stegaClean } from '@sanity/client/stega';
import { Badge } from '@/components/ui/badge';
import { Section, SectionContent } from '@/components/ui/section';
import { PortableText } from 'astro-portabletext';
import { portableTextComponents } from '@/components/portable-text';
import { JsonLd } from '@/components/ui/json-ld';
import { buildArticleJsonLd } from '@/lib/article-jsonld';
import ArticleNewsletterCta from '@/components/ArticleNewsletterCta.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const articles = await sanityClient.fetch<ALL_ARTICLE_SLUGS_QUERY_RESULT>(ALL_ARTICLE_SLUGS_QUERY, getSiteParams());
  return articles
    .filter((a): a is { slug: string } => typeof a.slug === 'string' && a.slug.length > 0)
    .map((a) => ({ params: { slug: a.slug } }));
};

const { slug } = Astro.params;
const article = await getArticleBySlug(slug as string);
if (!article) return Astro.redirect('/404');

// Site settings + Article JSON-LD (Story 19.6)
const siteSettings = await getSiteSettings();
const articleJsonLd = buildArticleJsonLd(article, siteSettings, Astro.url.href);

// Featured image — above-fold LCP candidate
const imageBuilder = safeUrlFor(article.featuredImage);
const imageUrl = imageBuilder?.width(1200).height(630).url() ?? null;
const lqip = article.featuredImage?.asset?.metadata?.lqip ?? null;
const imageDimensions = article.featuredImage?.asset?.metadata?.dimensions;

// Date formatting
const formattedDate = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

// Author
const authorSlug = article.author?.slug ? stegaClean(article.author.slug) : null;

// Category
const categoryTitle = article.category?.title ?? null;

// Related articles (max 3)
const relatedArticles = (article.relatedArticles ?? []).filter(Boolean).slice(0, 3);

// OG article tags — stegaClean all values for meta tags
const cleanPublishedAt = article.publishedAt ? stegaClean(article.publishedAt) : null;
const cleanUpdatedAt = article.updatedAt ? stegaClean(article.updatedAt) : null;
const cleanCategoryTitle = categoryTitle ? stegaClean(categoryTitle) : null;
const cleanTags = (article.tags ?? []).map((t: string) => stegaClean(t));
const cleanAuthorSlug = authorSlug;
---

<Layout
  title={article.title ?? 'Article'}
  seo={article.seo ?? { metaDescription: article.excerpt, ogImage: article.featuredImage }}
  ogType="article"
  preloadImage={imageUrl ?? undefined}
>
  <Fragment slot="head">
    {cleanPublishedAt && <meta property="article:published_time" content={cleanPublishedAt} />}
    {cleanUpdatedAt && <meta property="article:modified_time" content={cleanUpdatedAt} />}
    {cleanAuthorSlug && <meta property="article:author" content={`${Astro.url.origin}/authors/${cleanAuthorSlug}`} />}
    {cleanCategoryTitle && <meta property="article:section" content={cleanCategoryTitle} />}
    {cleanTags.map((tag: string) => (
      <meta property="article:tag" content={tag} />
    ))}
    <JsonLd schema={articleJsonLd} />
  </Fragment>

  <Section>
    <SectionContent>
      <Breadcrumb baseUrl={Astro.url.origin} items={[
        { label: 'Home', href: '/' },
        { label: 'Articles', href: '/articles' },
        { label: article.title ?? 'Article' },
      ]} />

      {imageUrl && (
        <div class="aspect-video overflow-hidden">
          <img
            src={imageUrl}
            alt={stegaClean(article.featuredImage?.alt) || stegaClean(article.title) || 'Article image'}
            class="w-full h-full object-cover"
            width={imageDimensions?.width ?? 1200}
            height={imageDimensions?.height ?? 630}
            loading="eager"
            fetchpriority="high"
            style={lqip ? `background-image: url(${lqip}); background-size: cover;` : undefined}
          />
        </div>
      )}

      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3 flex-wrap">
          {categoryTitle && (
            <Badge variant="outline">{article.category!.title}</Badge>
          )}
          {formattedDate && (
            <time datetime={article.publishedAt ? stegaClean(article.publishedAt) : undefined} class="text-sm text-muted-foreground">
              {formattedDate}
            </time>
          )}
        </div>

        <h1 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">
          {article.title}
        </h1>

        {article.author?.name && (
          <p class="text-muted-foreground">
            By{' '}
            {authorSlug ? (
              <a
                href={`/authors/${authorSlug}`}
                class="text-primary hover:text-primary/80 underline"
                data-gtm-category="author"
                data-gtm-action="detail"
                data-gtm-label={stegaClean(article.author.name)}
              >
                {article.author.name}
              </a>
            ) : (
              <span>{article.author.name}</span>
            )}
          </p>
        )}
      </div>

      {article.body && (
        <div class="prose max-w-none">
          <PortableText value={article.body} components={portableTextComponents} />
        </div>
      )}

      <ArticleNewsletterCta variant="article-body" />

      {relatedArticles.length > 0 && (
        <div>
          <h2 class="text-2xl font-bold mb-6">Related Articles</h2>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {relatedArticles.map((related) => (
              <ArticleCard article={related} />
            ))}
          </div>
        </div>
      )}

      <a href="/articles" class="inline-flex items-center gap-2 text-muted-foreground hover:text-foreground text-sm" data-gtm-category="navigation" data-gtm-label="back-to-articles">
        &larr; Back to Articles
      </a>
    </SectionContent>
  </Section>
</Layout>
