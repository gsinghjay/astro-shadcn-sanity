---
import "../styles/global.css";
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import ChatBubble from "../components/ChatBubble.astro";
import VisualEditingMPA from "../components/VisualEditingMPA";
import SanityLiveUpdater from "../components/SanityLiveUpdater.astro";
import { getSiteSettings, getSyncTags } from "../lib/sanity";
import { urlFor } from "../lib/image";
import { stegaClean } from "@sanity/client/stega";
import { PUBLIC_SANITY_VISUAL_EDITING_ENABLED, PUBLIC_GTM_ID, PUBLIC_SITE_THEME, PUBLIC_SANITY_LIVE_CONTENT_ENABLED } from "astro:env/client";
import type { SeoProps } from "@/lib/types";
import { buildOrgJsonLd } from "@/lib/org-jsonld";
import { buildPageGraph } from "@/lib/page-jsonld";

interface Props {
  title?: string;
  seo?: SeoProps | null;
  ogType?: string;
  preloadImage?: string;
  preloadImageSrcset?: string;
  preloadImageSizes?: string;
}

const siteSettings = await getSiteSettings();
const defaultTitle = siteSettings?.siteName || "YWCC Industry Capstone";
const defaultDescription = siteSettings?.siteDescription || "";

const {
  title = defaultTitle,
  seo,
  ogType,
  preloadImage,
  preloadImageSrcset,
  preloadImageSizes,
} = Astro.props;

const cleanTitle = stegaClean(title);
const cleanSeoTitle = seo?.metaTitle ? stegaClean(seo.metaTitle) : null;
const cleanDescription = stegaClean(
  seo?.metaDescription ?? defaultDescription
);

const visualEditingEnabled = PUBLIC_SANITY_VISUAL_EDITING_ENABLED;
const gtmId = PUBLIC_GTM_ID;

const fullTitle = cleanSeoTitle
  ? cleanSeoTitle
  : cleanTitle === stegaClean(defaultTitle)
    ? cleanTitle
    : `${cleanTitle} | ${stegaClean(defaultTitle)}`;

const ogTitle = cleanSeoTitle ?? cleanTitle;
const ogImageUrl = seo?.ogImage?.asset
  ? urlFor(seo.ogImage as Parameters<typeof urlFor>[0]).width(1200).height(630).url()
  : null;

const siteTheme = PUBLIC_SITE_THEME;
const liveContentEnabled = PUBLIC_SANITY_LIVE_CONTENT_ENABLED;

const syncTags = liveContentEnabled || visualEditingEnabled ? getSyncTags() : [];

// Extract AI Search worker origin for CSP connect-src (scoped, not wildcard).
// new URL() throws on malformed input — guard so a misconfigured apiUrl doesn't 500 every page.
const aiSearchApiUrl = (siteSettings?.aiSearch?.enabled || siteSettings?.aiSearch?.searchModalEnabled)
  ? stegaClean(siteSettings.aiSearch.apiUrl ?? "")
  : "";
let aiSearchWorkerOrigin = "";
if (aiSearchApiUrl) {
  try {
    aiSearchWorkerOrigin = new URL(aiSearchApiUrl).origin;
  } catch {
    aiSearchWorkerOrigin = "";
  }
}

const cspConnectSrc = [
  "'self'",
  "https://www.google-analytics.com",
  "https://www.googletagmanager.com",
  "https://*.sanity.io",
  "wss://*.sanity.io",
  "https://cloudflareinsights.com",
  "https://*.formsite.com",
  ...(aiSearchWorkerOrigin ? [aiSearchWorkerOrigin] : []),
].join(" ");

const cspContent = "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://challenges.cloudflare.com https://static.cloudflareinsights.com https://*.formsite.com; img-src 'self' https://cdn.sanity.io https://placehold.co https://www.googletagmanager.com https://avatars.githubusercontent.com https://i.ytimg.com https://*.formsite.com data:; style-src 'self' 'unsafe-inline'; connect-src " + cspConnectSrc + "; font-src 'self'; frame-src 'self' https://www.googletagmanager.com https://challenges.cloudflare.com https://www.youtube-nocookie.com https://*.formsite.com";

const hasStructuredData = Astro.slots.has('structured-data');
const fallbackOrgJsonLd = hasStructuredData ? null : buildPageGraph(await buildOrgJsonLd(Astro.url.origin));
---

<!doctype html>
<html lang="en" data-site-theme={siteTheme}>
  <head>
    <Font cssVariable="--font-inter" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={cleanDescription} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={cleanDescription} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content={ogType ?? 'website'} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={cleanDescription} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <link rel="canonical" href={Astro.url.href} />
    {seo?.noIndex && <meta name="robots" content="noindex" />}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${stegaClean(siteSettings?.siteName) ?? 'YWCC Industry Capstone'} — Articles`}
      href="/rss.xml"
    />
    <slot name="head" />
    <meta
      http-equiv="Content-Security-Policy"
      content={cspContent}
    />
    {hasStructuredData ? <slot name="structured-data" /> : <script type="application/ld+json" set:html={JSON.stringify(fallbackOrgJsonLd)} />}
    {preloadImage && !preloadImageSrcset && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    {preloadImageSrcset && <link rel="preload" as="image" imagesrcset={preloadImageSrcset} imagesizes={preloadImageSizes || '100vw'} fetchpriority="high" />}
    <title>{fullTitle}</title>
    {(liveContentEnabled || visualEditingEnabled) && syncTags.length > 0 && (
      <script define:vars={{ syncTags }}>
        window.__SANITY_SYNC_TAGS__ = syncTags;
      </script>
    )}
    {gtmId && (
      <script define:vars={{ pagePath: Astro.url.pathname, pageTitle: fullTitle }}>
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'page_view',
          page: {
            path: pagePath,
            title: pageTitle,
          }
        });
      </script>
    )}
  </head>
  <body class="antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script src="../scripts/main.ts"></script>
    {visualEditingEnabled && <VisualEditingMPA client:only="react" />}
    {(liveContentEnabled || visualEditingEnabled) && <SanityLiveUpdater />}
    <CookieConsent gtmId={gtmId} />
    {siteSettings?.aiSearch?.enabled && siteSettings.aiSearch.apiUrl && (
      <ChatBubble
        apiUrl={siteSettings.aiSearch.apiUrl}
        placeholder={siteSettings.aiSearch.placeholder}
        theme={siteSettings.aiSearch.theme}
        hideBranding={siteSettings.aiSearch.hideBranding}
        openByDefault={siteSettings.aiSearch.openByDefault}
      />
    )}
  </body>
</html>
