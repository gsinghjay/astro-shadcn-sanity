---
import { urlFor } from '@/lib/image';

interface Props {
  image: {
    asset?: {
      _id: string;
      url?: string | null;
      metadata?: {
        lqip?: string | null;
        dimensions?: { width: number; height: number; aspectRatio: number } | null;
      } | null;
    } | null;
    alt?: string | null;
    hotspot?: { x: number; y: number; width: number; height: number } | null;
    crop?: { top: number; bottom: number; left: number; right: number } | null;
  };
  width: number;
  height: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'sync' | 'auto';
  sizes?: string;
  srcsetWidths?: number[];
}

const {
  image,
  width,
  height,
  class: className,
  loading = 'lazy',
  fetchpriority,
  decoding = 'async',
  sizes,
  srcsetWidths = [640, 960, 1280, 1920],
} = Astro.props;

const lqip = image.asset?.metadata?.lqip;
const alt = image.alt || '';

const optimizedUrl = image.asset
  ? urlFor(image).width(width).height(height).fit('crop').url()
  : '';

const srcset = image.asset
  ? srcsetWidths
      .map(w => {
        const h = Math.round(w * height / width);
        return `${urlFor(image).width(w).height(h).fit('crop').url()} ${w}w`;
      })
      .join(', ')
  : undefined;
---

{lqip ? (
  <div style={`background-image: url(${lqip}); background-size: cover;`}>
    <img
      src={optimizedUrl}
      srcset={srcset}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      fetchpriority={fetchpriority}
      decoding={decoding}
      sizes={sizes || '100vw'}
      class={className}
    />
  </div>
) : (
  <img
    src={optimizedUrl}
    srcset={srcset}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
    sizes={sizes || '100vw'}
    class={className}
  />
)}
