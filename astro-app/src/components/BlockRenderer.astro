---
import type { PageBlock, InnerPageBlock } from '@/lib/types';
import type { Sponsor, Project, Testimonial, SanityEvent, Article } from '@/lib/sanity';
import { resolveBlockSponsors, resolveBlockProjects, resolveBlockTestimonials, resolveBlockEvents, resolveBlockArticles } from '@/lib/sanity';
import { allBlocks, resolveContainerBlocks } from './block-registry';
import BlockWrapper from './BlockWrapper.astro';

interface Props {
  blocks: (PageBlock | InnerPageBlock)[];
  sponsors?: Sponsor[];
  projects?: Project[];
  testimonials?: Testimonial[];
  events?: SanityEvent[];
  articles?: Article[];
}

const { blocks, sponsors = [], projects = [], testimonials = [], events = [], articles = [] } = Astro.props;

// Resolve lazily-loaded container blocks (e.g. ColumnsBlock) before rendering
await resolveContainerBlocks();

function getBlockExtraProps(block: PageBlock | InnerPageBlock): Record<string, unknown> {
  switch (block._type) {
    case 'logoCloud':
    case 'sponsorCards':
      return { sponsors: resolveBlockSponsors(block, sponsors) };
    case 'projectCards':
      return { projects: resolveBlockProjects(block, projects) };
    case 'testimonials':
      return { testimonials: resolveBlockTestimonials(block, testimonials) };
    case 'eventList':
      return { events: resolveBlockEvents(block, events) };
    case 'articleList':
      return { articles: resolveBlockArticles(block, articles) };
    case 'columnsBlock':
      return { sponsors, projects, testimonials, events, articles };
    default:
      return {};
  }
}
---

{blocks.map((block) => {
  const Component = allBlocks[block._type];
  if (!Component) return null;
  const extraProps = getBlockExtraProps(block);
  return <BlockWrapper backgroundVariant={block.backgroundVariant} spacing={block.spacing} maxWidth={block.maxWidth} alignment={block.alignment} blockType={block._type}><Component {...block} {...extraProps} /></BlockWrapper>;
})}
