---
import { getVideoId } from '@/lib/video';

interface Props {
  url: string;
  title?: string;
  class?: string;
}

const { url, title, class: className } = Astro.props;
const videoId = getVideoId(url);
const videoTitle = title ?? 'Video';
---

{videoId && (
  <div class:list={['aspect-video w-full overflow-hidden rounded-md relative', className]} data-youtube-facade={videoId}>
    <img
      src={`https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`}
      alt={`Video thumbnail: ${videoTitle}`}
      width="480"
      height="360"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover"
    />
    <button
      aria-label={`Play video: ${videoTitle}`}
      class="absolute inset-0 flex items-center justify-center bg-black/20 hover:bg-black/40 transition-colors cursor-pointer group"
    >
      <svg class="w-16 h-16 text-white drop-shadow-lg group-hover:scale-110 transition-transform" viewBox="0 0 68 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/>
        <path d="M45 24L27 14v20" fill="white"/>
      </svg>
    </button>
  </div>
)}

<script>
  document.querySelectorAll<HTMLDivElement>('[data-youtube-facade]').forEach(el => {
    el.addEventListener('click', () => {
      const id = el.dataset.youtubeFacade;
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.className = 'w-full h-full border-0 absolute inset-0';
      el.replaceChildren(iframe);
    }, { once: true });
  });
</script>
