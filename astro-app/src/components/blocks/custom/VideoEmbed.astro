---
import type { VideoEmbedBlock } from '@/lib/types';
import VideoEmbedComponent from '@/components/VideoEmbed.astro';
import { Section, SectionContent, SectionSplit, SectionGrid, SectionProse } from '@/components/ui/section';
import { stegaClean } from '@sanity/client/stega';
import { safeUrlFor } from '@/lib/image';
import { JsonLd } from '@/components/ui/json-ld';
import { getVideoId } from '@/lib/video';

type Props = VideoEmbedBlock;

const { heading, description, videoUrl: rawVideoUrl, posterImage, variant: rawVariant } = Astro.props;
const videoUrl = stegaClean(rawVideoUrl);
const variant = (() => {
  const v = stegaClean(rawVariant);
  return v === 'split' || v === 'split-asymmetric' ? v : 'full-width';
})();

const posterUrl = safeUrlFor(posterImage)?.width(1280).height(720).url() ?? undefined;

const videoId = videoUrl ? getVideoId(videoUrl) : null;
const videoJsonLd = videoUrl && videoId ? {
  "@type": "VideoObject",
  "name": stegaClean(heading) || "Video",
  ...(description && { "description": stegaClean(description) }),
  "thumbnailUrl": `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`,
  "embedUrl": `https://www.youtube-nocookie.com/embed/${videoId}`,
  "contentUrl": videoUrl,
} : null;
---

{videoJsonLd && <JsonLd schema={videoJsonLd} />}

{variant === 'full-width' && videoUrl && (
  <Section data-animate>
    {(heading || description) && (
      <SectionContent class="items-center text-center mb-8">
        {heading && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.03em] leading-[1.1]">{heading}</h2>
        )}
        {description && (
          <p class="text-muted-foreground leading-relaxed max-w-2xl mx-auto">{description}</p>
        )}
      </SectionContent>
    )}
    <VideoEmbedComponent url={videoUrl} title={heading ?? undefined} />
  </Section>
)}

{variant === 'split' && videoUrl && (
  <Section data-animate>
    <SectionSplit>
      <SectionContent class="justify-center">
        {heading && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.03em] leading-[1.1]">{heading}</h2>
        )}
        {description && (
          <p class="text-muted-foreground leading-relaxed">{description}</p>
        )}
      </SectionContent>
      <div>
        <VideoEmbedComponent url={videoUrl} title={heading ?? undefined} />
      </div>
    </SectionSplit>
  </Section>
)}

{variant === 'split-asymmetric' && videoUrl && (
  <Section data-animate>
    <SectionSplit class="@5xl:grid-cols-[1fr_3fr] @5xl:items-start">
      <SectionContent class="@5xl:sticky @5xl:top-[calc(24px+var(--header-height,0px))]">
        {heading && (
          <SectionProse size="sm">
            <h2>{heading}</h2>
            {description && <p>{description}</p>}
          </SectionProse>
        )}
      </SectionContent>
      <SectionGrid class="grid-cols-1 gap-1 @5xl:grid-cols-2">
        <div class="@5xl:col-span-2">
          <VideoEmbedComponent url={videoUrl} title={heading ?? undefined} />
        </div>
        {posterImage && posterUrl && (
          <img
            src={posterUrl}
            alt={posterImage.alt ?? ''}
            width="640"
            height="360"
            loading="lazy"
            class="w-full h-auto object-cover"
          />
        )}
      </SectionGrid>
    </SectionSplit>
  </Section>
)}
