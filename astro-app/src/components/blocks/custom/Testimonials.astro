---
import type { Testimonial } from '@/lib/sanity';
import { Section, SectionContent, SectionSplit, SectionGrid, SectionMasonry } from '@/components/ui/section';
import {
  NativeCarousel,
  NativeCarouselContent,
  NativeCarouselItem,
  NativeCarouselNext,
  NativeCarouselPrevious,
} from '@/components/ui/native-carousel';
import { Marquee, MarqueeContent } from '@/components/ui/marquee';
import TestimonialCard from '@/components/TestimonialCard.astro';
import { stegaClean } from '@sanity/client/stega';
import { safeUrlFor } from '@/lib/image';
import { JsonLd } from '@/components/ui/json-ld';

interface Props {
  heading?: string | null;
  testimonialSource?: 'all' | 'industry' | 'student' | 'byProject' | 'manual' | null;
  testimonials?: Testimonial[];
  variant?: string;
  class?: string;
  id?: string;
  [key: string]: unknown;
}

const { heading, testimonialSource, testimonials = [], variant, class: className, id } = Astro.props;

const reviewsJsonLd = testimonials.filter(t => t.name && t.quote).map(t => ({
  "@type": "Review",
  "reviewBody": stegaClean(t.quote),
  "author": {
    "@type": "Person",
    "name": stegaClean(t.name),
    ...(t.role && { "jobTitle": stegaClean(t.role) }),
    ...(t.organization && { "worksFor": { "@type": "Organization", "name": stegaClean(t.organization) } }),
  },
}));
const rawVariant = stegaClean(variant);
const cleanVariant =
  rawVariant === 'grid' ||
  rawVariant === 'masonry' ||
  rawVariant === 'split' ||
  rawVariant === 'carousel' ||
  rawVariant === 'marquee' ||
  rawVariant === 'brutalist-quote' ||
  rawVariant === 'spotlight'
    ? rawVariant
    : 'grid';

// For byProject mode, group testimonials by project reference
const isByProject = stegaClean(testimonialSource) === 'byProject';
const grouped = new Map<string, { title: string; slug: string; testimonials: Testimonial[] }>();
if (isByProject) {
  for (const t of testimonials) {
    if (!t.project) continue;
    const key = t.project._id;
    if (!grouped.has(key)) {
      grouped.set(key, { title: t.project.title ?? '', slug: t.project.slug ?? '', testimonials: [] });
    }
    grouped.get(key)!.testimonials.push(t);
  }
}
---

{reviewsJsonLd.length > 0 && reviewsJsonLd.map(r => <JsonLd schema={r} />)}

{cleanVariant === 'grid' && (
  <Section data-animate class={className} id={id}>
    {heading && (
      <SectionContent>
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    {isByProject ? (
      <SectionContent>
        {[...grouped.entries()].map(([, group]) => (
          <div class="mb-10 last:mb-0">
            <h3 class="text-2xl font-bold mb-4">
              <a href={`/projects/${group.slug}`} class="hover:text-primary transition-colors">
                {group.title}
              </a>
            </h3>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {group.testimonials.map((t) => (
                <TestimonialCard testimonial={t} />
              ))}
            </div>
          </div>
        ))}
      </SectionContent>
    ) : (
      <SectionContent>
        {testimonials.length > 0 ? (
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {testimonials.map((t) => (
              <TestimonialCard testimonial={t} />
            ))}
          </div>
        ) : (
          <p class="text-muted-foreground text-center py-8">No testimonials to display.</p>
        )}
      </SectionContent>
    )}
  </Section>
)}

{cleanVariant === 'masonry' && (
  <Section data-animate class={className} id={id}>
    {heading && (
      <SectionContent>
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}
    {testimonials.length > 0 ? (
      <SectionMasonry>
        {testimonials.map((t) => (
          <TestimonialCard testimonial={t} />
        ))}
      </SectionMasonry>
    ) : (
      <SectionContent>
        <p class="text-muted-foreground text-center py-8">No testimonials to display.</p>
      </SectionContent>
    )}
  </Section>
)}

{cleanVariant === 'split' && (
  <Section data-animate class={className} id={id}>
    <SectionSplit>
      <SectionContent>
        {heading && (
          <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
        )}
      </SectionContent>
      {testimonials.length > 0 ? (
        <SectionGrid class="grid-cols-1">
          {testimonials.map((t) => (
            <TestimonialCard testimonial={t} />
          ))}
        </SectionGrid>
      ) : (
        <div class="text-muted-foreground text-center py-8">No testimonials to display.</div>
      )}
    </SectionSplit>
  </Section>
)}

{cleanVariant === 'carousel' && (
  <Section data-animate class={className} id={id} style={{ '--section-width': 'var(--breakpoint-sm)' }}>
    <SectionContent class="items-center text-center">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
    </SectionContent>
    {testimonials.length > 0 ? (
      <NativeCarousel>
        <NativeCarouselContent>
          {testimonials.map((t) => (
            <NativeCarouselItem>
              <TestimonialCard testimonial={t} />
            </NativeCarouselItem>
          ))}
        </NativeCarouselContent>
        <NativeCarouselPrevious class="top-auto -bottom-2 left-6" />
        <NativeCarouselNext class="top-auto right-6 -bottom-2" />
      </NativeCarousel>
    ) : (
      <p class="text-muted-foreground text-center py-8">No testimonials to display.</p>
    )}
  </Section>
)}

{cleanVariant === 'marquee' && (
  <Section data-animate class={className} id={id}>
    {heading && (
      <SectionContent class="items-center text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}
    {testimonials.length > 0 ? (
      <>
        {(['left', 'right'] as const).map((direction) => (
          <Marquee class={direction === 'right' ? 'mask-x-from-95%' : ''}>
            <MarqueeContent direction={direction} pauseOnHover>
              {[...testimonials, ...testimonials].map((t) => (
                <TestimonialCard testimonial={t} />
              ))}
            </MarqueeContent>
          </Marquee>
        ))}
      </>
    ) : (
      <p class="text-muted-foreground text-center py-8">No testimonials to display.</p>
    )}
  </Section>
)}

{cleanVariant === 'brutalist-quote' && (
  <Section data-animate class={className} id={id}>
    {heading && (
      <SectionContent class="items-center text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}
    {testimonials.length > 0 ? (
      <NativeCarousel>
        <NativeCarouselContent>
          {testimonials.map((t) => {
            const photoUrl = t.photo
              ? safeUrlFor(t.photo)?.width(80).height(80).fit('crop').url() ?? null
              : null;
            return (
              <NativeCarouselItem>
                <div class="relative p-8 md:p-12 max-w-4xl mx-auto">
                  <div class="text-[8rem] leading-none text-primary/20 font-serif absolute top-0 left-4 select-none" aria-hidden="true">&ldquo;</div>
                  <blockquote class="relative z-10 text-2xl md:text-3xl lg:text-4xl font-bold tracking-[-0.03em] leading-[1.1] mb-8">
                    <p>{t.quote}</p>
                    <footer class="flex items-center gap-3 font-mono mt-8 text-base font-normal tracking-normal leading-normal">
                      {photoUrl ? (
                        <img src={photoUrl} alt={stegaClean(t.photo?.alt) || stegaClean(t.name) || 'Testimonial author'} width="48" height="48" loading="lazy" class="w-12 h-12 object-cover" />
                      ) : (
                        <div class="w-12 h-12 bg-muted flex items-center justify-center">
                          <span class="text-sm font-bold text-muted-foreground">
                            {(t.name || '').split(' ').filter(Boolean).map((w: string) => w[0]).join('').slice(0, 2)}
                          </span>
                        </div>
                      )}
                      <cite class="not-italic">
                        <span class="font-bold text-sm">{t.name}</span>
                        {t.role && <span class="block text-xs text-muted-foreground">{t.role}</span>}
                        {t.organization && <span class="block text-xs text-muted-foreground">{t.organization}</span>}
                      </cite>
                    </footer>
                  </blockquote>
                </div>
              </NativeCarouselItem>
            );
          })}
        </NativeCarouselContent>
        <NativeCarouselPrevious class="top-auto -bottom-2 left-6" />
        <NativeCarouselNext class="top-auto right-6 -bottom-2" />
      </NativeCarousel>
    ) : (
      <p class="text-muted-foreground text-center py-8">No testimonials to display.</p>
    )}
  </Section>
)}

{cleanVariant === 'spotlight' && (
  <Section data-animate class={className} id={id}>
    {heading && (
      <SectionContent class="items-center text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}
    {testimonials.length > 0 ? (
      <SectionContent>
        {(() => {
          const t = testimonials[0];
          const photoUrl = t.photo
            ? safeUrlFor(t.photo)?.width(200).height(200).fit('crop').url() ?? null
            : null;
          return (
            <div class="flex flex-col md:flex-row gap-8 items-center">
              <div class="flex-shrink-0">
                {photoUrl ? (
                  <img src={photoUrl} alt={stegaClean(t.photo?.alt) || stegaClean(t.name) || 'Testimonial author'} width="200" height="200" loading="lazy" class="w-48 h-48 object-cover border-2 border-border" />
                ) : (
                  <div class="w-48 h-48 bg-muted flex items-center justify-center border-2 border-border">
                    <span class="text-4xl font-bold text-muted-foreground">
                      {(t.name || '').split(' ').filter(Boolean).map((w: string) => w[0]).join('').slice(0, 2)}
                    </span>
                  </div>
                )}
              </div>
              <div class="flex-1 space-y-4">
                <blockquote class="text-2xl md:text-3xl font-bold tracking-[-0.03em] leading-[1.1]">
                  <p>&ldquo;{t.quote}&rdquo;</p>
                  <footer class="mt-4 font-normal tracking-normal leading-normal">
                    <cite class="not-italic">
                      <span class="text-lg font-bold">{t.name}</span>
                      {t.role && <span class="block text-muted-foreground text-base">{t.role}</span>}
                    </cite>
                    {t.organization && <span class="block text-lg font-semibold text-primary">{t.organization}</span>}
                  </footer>
                </blockquote>
              </div>
            </div>
          );
        })()}
      </SectionContent>
    ) : (
      <p class="text-muted-foreground text-center py-8">No testimonials to display.</p>
    )}
  </Section>
)}
