---
import type { TimelineBlock } from '@/lib/types';
import { Section, SectionContent, SectionActions } from '@/components/ui/section';
import { Button } from '@/components/ui/button';
import { stegaClean } from '@sanity/client/stega';
import { safeUrlFor } from '@/lib/image';

interface Props extends TimelineBlock {
  class?: string;
  id?: string;
}

const { heading, description, items, links, variant: rawVariant } = Astro.props;
const variant = stegaClean(rawVariant) ?? 'vertical';
const entries = items ?? [];
---

{variant === 'vertical' && (
  <Section data-animate>
    <SectionContent>
      {heading && (
        <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.03em] leading-[1.1]">{heading}</h2>
      )}
      {description && (
        <p class="text-muted-foreground leading-relaxed max-w-2xl">{description}</p>
      )}

      <div class="relative before:absolute before:left-[60px] before:top-0 before:h-full before:w-px before:bg-border">
        {entries.map((entry) => {
          const imgSrc = safeUrlFor(entry.image)?.width(400).height(300).fit('crop').url() ?? null;
          const lqip = entry.image?.asset?.metadata?.lqip;
          return (
            <div class="relative flex gap-6 pb-8 last:pb-0">
              <div class="w-[60px] flex-shrink-0 text-right pr-4">
                <span class="label-caps text-muted-foreground">{entry.date}</span>
              </div>
              <div class="flex-1 pt-px">
                <h3 class="font-semibold">{entry.title}</h3>
                {entry.description && (
                  <p class="text-muted-foreground mt-1">{entry.description}</p>
                )}
                {imgSrc && (
                  <img
                    src={imgSrc}
                    alt={entry.image?.alt || entry.title || ''}
                    width={400}
                    height={300}
                    class="mt-3 rounded"
                    loading="lazy"
                    decoding="async"
                    style={lqip ? `background-image: url(${lqip}); background-size: cover;` : undefined}
                  />
                )}
              </div>
            </div>
          );
        })}
      </div>

      {links && links.length > 0 && (
        <SectionActions>
          {links.map((link, i) => (
            <Button
              href={link.url}
              variant={link.variant || (i === 0 ? 'default' : 'outline')}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(link.text)}
            >
              {link.text}
            </Button>
          ))}
        </SectionActions>
      )}
    </SectionContent>
  </Section>
)}

{variant === 'split' && (
  <Section data-animate>
    <SectionContent>
      {heading && (
        <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.03em] leading-[1.1]">{heading}</h2>
      )}
      {description && (
        <p class="text-muted-foreground leading-relaxed max-w-2xl">{description}</p>
      )}

      <div class="relative grid grid-cols-1 @3xl:grid-cols-[1fr_auto_1fr] gap-x-6">
        <div class="col-start-2 absolute top-0 h-full w-px bg-border"></div>
        {entries.map((entry, i) => {
          const isLeft = i % 2 === 0;
          const imgSrc = safeUrlFor(entry.image)?.width(400).height(300).fit('crop').url() ?? null;
          const lqip = entry.image?.asset?.metadata?.lqip;
          return (
            <>
              {isLeft ? (
                <>
                  <div class="text-right pb-8">
                    <span class="label-caps text-muted-foreground">{entry.date}</span>
                    <h3 class="font-semibold mt-1">{entry.title}</h3>
                    {entry.description && (
                      <p class="text-muted-foreground mt-1">{entry.description}</p>
                    )}
                    {imgSrc && (
                      <img
                        src={imgSrc}
                        alt={entry.image?.alt || entry.title || ''}
                        width={400}
                        height={300}
                        class="mt-3 rounded ml-auto"
                        loading="lazy"
                        decoding="async"
                        style={lqip ? `background-image: url(${lqip}); background-size: cover;` : undefined}
                      />
                    )}
                  </div>
                  <div></div>
                  <div class="pb-8"></div>
                </>
              ) : (
                <>
                  <div class="pb-8"></div>
                  <div></div>
                  <div class="pb-8">
                    <span class="label-caps text-muted-foreground">{entry.date}</span>
                    <h3 class="font-semibold mt-1">{entry.title}</h3>
                    {entry.description && (
                      <p class="text-muted-foreground mt-1">{entry.description}</p>
                    )}
                    {imgSrc && (
                      <img
                        src={imgSrc}
                        alt={entry.image?.alt || entry.title || ''}
                        width={400}
                        height={300}
                        class="mt-3 rounded"
                        loading="lazy"
                        decoding="async"
                        style={lqip ? `background-image: url(${lqip}); background-size: cover;` : undefined}
                      />
                    )}
                  </div>
                </>
              )}
            </>
          );
        })}
      </div>

      {links && links.length > 0 && (
        <SectionActions>
          {links.map((link, i) => (
            <Button
              href={link.url}
              variant={link.variant || (i === 0 ? 'default' : 'outline')}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(link.text)}
            >
              {link.text}
            </Button>
          ))}
        </SectionActions>
      )}
    </SectionContent>
  </Section>
)}

{variant === 'horizontal' && (
  <Section data-animate>
    <SectionContent>
      {heading && (
        <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.03em] leading-[1.1]">{heading}</h2>
      )}

      <div class="overflow-x-auto">
        <div class="flex relative before:absolute before:top-[24px] before:left-0 before:w-full before:h-px before:bg-border">
          {entries.map((entry) => {
            const imgSrc = safeUrlFor(entry.image)?.width(300).height(200).fit('crop').url() ?? null;
            const lqip = entry.image?.asset?.metadata?.lqip;
            return (
              <div class="min-w-[200px] flex-shrink-0 px-4 first:pl-0 last:pr-0">
                <span class="label-caps text-muted-foreground relative z-10 bg-background pr-2">{entry.date}</span>
                <div class="mt-4">
                  <h3 class="font-semibold">{entry.title}</h3>
                  {imgSrc && (
                    <img
                      src={imgSrc}
                      alt={entry.image?.alt || entry.title || ''}
                      width={300}
                      height={200}
                      class="mt-2 rounded"
                      loading="lazy"
                      decoding="async"
                      style={lqip ? `background-image: url(${lqip}); background-size: cover;` : undefined}
                    />
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>

      {links && links.length > 0 && (
        <SectionActions>
          {links.map((link, i) => (
            <Button
              href={link.url}
              variant={link.variant || (i === 0 ? 'default' : 'outline')}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(link.text)}
            >
              {link.text}
            </Button>
          ))}
        </SectionActions>
      )}
    </SectionContent>
  </Section>
)}

{variant === 'engineering' && (
  <Section data-animate>
    <SectionContent>
      {heading && (
        <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.03em] leading-[1.1]">{heading}</h2>
      )}
      {description && (
        <p class="text-muted-foreground leading-relaxed max-w-2xl">{description}</p>
      )}

      <div class="relative before:absolute before:left-[11px] before:top-0 before:h-full before:w-[2px] before:border-l-2 before:border-dashed before:border-primary/40">
        {entries.map((entry) => (
          <div class="relative flex gap-6 pb-8 last:pb-0">
            <div class="relative flex-shrink-0 mt-1">
              <div class="w-[24px] h-[24px] bg-primary border-brutal border-primary"></div>
            </div>
            <div class="flex-1">
              <span class="font-mono label-caps text-muted-foreground tracking-wider">{entry.date}</span>
              <div class="border-l-4 border-primary pl-4 mt-2">
                <h3 class="font-semibold">{entry.title}</h3>
                {entry.description && (
                  <p class="text-muted-foreground mt-1 text-sm">{entry.description}</p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      {links && links.length > 0 && (
        <SectionActions>
          {links.map((link, i) => (
            <Button
              href={link.url}
              variant={link.variant || (i === 0 ? 'default' : 'outline')}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(link.text)}
            >
              {link.text}
            </Button>
          ))}
        </SectionActions>
      )}
    </SectionContent>
  </Section>
)}
