---
import { Section, SectionContent, SectionGrid } from '@/components/ui/section';
import { Tile, TileContent, TileTitle, TileDescription } from '@/components/ui/tile';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { stegaClean } from '@sanity/client/stega';
import { cn, blockBaseClasses } from '@/lib/utils';

interface Props {
  heading?: string;
  description?: string;
  tiers?: Array<{
    _key: string;
    name: string;
    price: string;
    interval?: string;
    description?: string;
    features: string[];
    highlighted?: boolean;
    ctaText?: string;
    ctaUrl?: string;
  }>;
  variant?: string;
  backgroundVariant?: string;
  spacing?: string;
  maxWidth?: string;
  class?: string;
  id?: string;
}

const { heading, description, tiers = [], variant: rawVariant, backgroundVariant, spacing, maxWidth, class: className, id } = Astro.props;
const cleanVariant = stegaClean(rawVariant) ?? 'simple';
const baseClasses = blockBaseClasses(stegaClean(backgroundVariant), stegaClean(spacing), stegaClean(maxWidth));
---

{cleanVariant === 'simple' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid>
      {tiers.map((tier) => (
        <Tile variant="floating" class={cn(tier.highlighted && 'border-primary ring-1 ring-primary')}>
          <TileContent>
            <TileTitle>{tier.name}</TileTitle>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-bold">{tier.price}</span>
              {tier.interval && <span class="text-muted-foreground">/{tier.interval}</span>}
            </div>
            {tier.description && <TileDescription>{tier.description}</TileDescription>}
            <ul class="space-y-2 text-sm">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-2">
                  <span class="text-primary mt-0.5">&#10003;</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            {tier.ctaText && (
              <Button href={tier.ctaUrl} variant={tier.highlighted ? 'default' : 'outline'} class="w-full mt-auto">
                {tier.ctaText}
              </Button>
            )}
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'featured' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    <SectionContent class="max-w-3xl mx-auto items-center text-center">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid>
      {tiers.map((tier) => (
        <Tile variant="floating" class={cn(
          'items-center text-center',
          tier.highlighted && 'border-primary ring-1 ring-primary scale-105 shadow-lg'
        )}>
          <TileContent class="items-center text-center">
            {tier.highlighted && <Badge>Most Popular</Badge>}
            <TileTitle class="text-2xl">{tier.name}</TileTitle>
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-bold">{tier.price}</span>
              {tier.interval && <span class="text-muted-foreground">/{tier.interval}</span>}
            </div>
            {tier.description && <TileDescription class="text-center">{tier.description}</TileDescription>}
            <ul class="space-y-2 text-sm w-full">
              {tier.features.map((feature) => (
                <li class="flex items-center gap-2 justify-center">
                  <span class="text-primary">&#10003;</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            {tier.ctaText && (
              <Button href={tier.ctaUrl} variant={tier.highlighted ? 'default' : 'outline'} class="w-full mt-auto">
                {tier.ctaText}
              </Button>
            )}
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'comparison' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <div class="w-full overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b">
            <th class="p-4 text-sm font-medium text-muted-foreground">Features</th>
            {tiers.map((tier) => (
              <th class={cn('p-4 text-center', tier.highlighted && 'bg-primary/5')}>
                <div class="font-bold text-lg">{tier.name}</div>
                <div class="text-2xl font-bold mt-1">{tier.price}</div>
                {tier.interval && <div class="text-sm text-muted-foreground">/{tier.interval}</div>}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {(tiers[0]?.features ?? []).map((_, featureIndex) => (
            <tr class="border-b">
              <td class="p-4 text-sm">{tiers[0]?.features[featureIndex]}</td>
              {tiers.map((tier) => (
                <td class={cn('p-4 text-center', tier.highlighted && 'bg-primary/5')}>
                  {featureIndex < tier.features.length ? (
                    <span class="text-primary">&#10003;</span>
                  ) : (
                    <span class="text-muted-foreground">&#8212;</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
        <tfoot>
          <tr>
            <td class="p-4"></td>
            {tiers.map((tier) => (
              <td class={cn('p-4 text-center', tier.highlighted && 'bg-primary/5')}>
                {tier.ctaText && (
                  <Button href={tier.ctaUrl} variant={tier.highlighted ? 'default' : 'outline'}>
                    {tier.ctaText}
                  </Button>
                )}
              </td>
            ))}
          </tr>
        </tfoot>
      </table>
    </div>
  </Section>
)}
