---
import { Section, SectionContent, SectionGrid, SectionSplit } from '@/components/ui/section';
import { Tile, TileContent, TileTitle, TileDescription } from '@/components/ui/tile';
import { stegaClean } from '@sanity/client/stega';
import { cn } from '@/lib/utils';
import { safeUrlFor } from '@/lib/image';
import type { ServiceCardsBlock } from '@/lib/types';

interface Props extends ServiceCardsBlock {
  class?: string;
  id?: string;
}

const { heading, description, services = [], variant: rawVariant, class: className, id } = Astro.props;
const rawCleaned = stegaClean(rawVariant);
const cleanVariant = rawCleaned === 'grid' || rawCleaned === 'list' || rawCleaned === 'alternating' || rawCleaned === 'icon-grid' || rawCleaned === 'specification' ? rawCleaned : 'grid';
---

{cleanVariant === 'grid' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid>
      {services.map((service) => (
        <Tile variant="floating" href={service.link?.href}>
          <TileContent>
            {service.icon && (
              <span class="text-3xl" aria-hidden="true">{service.icon}</span>
            )}
            <TileTitle>{service.title}</TileTitle>
            {service.description && <TileDescription>{service.description}</TileDescription>}
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'list' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <ul class="w-full space-y-4 list-none">
      {services.map((service) => (
        <li>
          <Tile variant="floating" href={service.link?.href}>
            <TileContent class="flex-row items-center gap-6">
              {service.icon && (
                <span class="text-3xl flex-shrink-0" aria-hidden="true">{service.icon}</span>
              )}
              <div class="flex-1 min-w-0">
                <TileTitle>{service.title}</TileTitle>
                {service.description && <TileDescription>{service.description}</TileDescription>}
              </div>
            </TileContent>
          </Tile>
        </li>
      ))}
    </ul>
  </Section>
)}

{cleanVariant === 'alternating' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <div class="w-full space-y-16">
      {services.map((service, i) => (
        <SectionSplit class={i % 2 !== 0 ? '@lg:direction-rtl' : ''}>
          <SectionContent>
            {service.icon && <span class="text-4xl" aria-hidden="true">{service.icon}</span>}
            <h3 class="text-2xl font-bold">{service.title}</h3>
            {service.description && (
              <p class="text-muted-foreground leading-relaxed">{service.description}</p>
            )}
          </SectionContent>
          <div class="bg-muted rounded-sm aspect-video flex items-center justify-center">
            {safeUrlFor(service.image) ? (
              <img src={safeUrlFor(service.image)!.width(800).height(450).fit('crop').url()} alt={stegaClean(service.image?.alt) || stegaClean(service.title) || 'Service image'} class="w-full h-full object-cover rounded-sm" loading="lazy" />
            ) : (
              <span class="text-6xl" aria-hidden="true">{service.icon || '📋'}</span>
            )}
          </div>
        </SectionSplit>
      ))}
    </div>
  </Section>
)}

{cleanVariant === 'icon-grid' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl mx-auto items-center text-center">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid size="sm">
      {services.map((service) => (
        <Tile variant="floating" href={service.link?.href} class="items-center text-center">
          <TileContent class="items-center text-center">
            {service.icon && (
              <span class="text-4xl" aria-hidden="true">{service.icon}</span>
            )}
            <TileTitle>{service.title}</TileTitle>
            {service.description && <TileDescription class="text-center">{service.description}</TileDescription>}
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'specification' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <div class="w-full space-y-0">
      {services.map((service, i) => (
        <div class="flex items-start gap-6 border-l-4 border-primary pl-6 py-6 border-b border-border last:border-b-0">
          <span class="font-mono text-2xl font-bold text-primary/30 flex-shrink-0 leading-none mt-1" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>
          {service.icon && (
            <div class="w-12 h-12 flex-shrink-0 flex items-center justify-center border-brutal border-foreground/20">
              <span class="text-2xl" aria-hidden="true">{service.icon}</span>
            </div>
          )}
          <div class="flex-1 min-w-0">
            <h3 class="font-mono font-bold text-lg">{service.title}</h3>
            {service.description && (
              <p class="text-sm text-muted-foreground mt-1">{service.description}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  </Section>
)}
