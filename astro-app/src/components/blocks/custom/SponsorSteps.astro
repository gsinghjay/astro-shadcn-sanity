---
import type { SponsorStepsBlock } from '@/lib/types';
import CircleCheck from 'lucide-static/icons/circle-check.svg';
import { Button } from '@/components/ui/button';
import { stegaClean } from '@sanity/client/stega';
import { List, ListItem } from '@/components/ui/list';
import {
  Section,
  SectionActions,
  SectionContent,
  SectionProse,
  SectionSplit,
  SectionGrid,
  SectionSpread,
} from '@/components/ui/section';
import {
  Tile,
  TileContent,
  TileDescription,
  TileMedia,
  TileTitle,
} from '@/components/ui/tile';

interface Props extends SponsorStepsBlock {
  class?: string;
  id?: string;
}

const { heading, subheading, items, ctaButtons, variant } = Astro.props;
const rawVariant = stegaClean(variant);
const cleanVariant = rawVariant === 'steps' || rawVariant === 'split' || rawVariant === 'spread' ? rawVariant : 'steps';
---

{cleanVariant === 'steps' && (
  <Section>
    <SectionContent>
      {(heading || subheading) && (
        <SectionProse>
          {heading && <h2>{heading}</h2>}
          {subheading && <p>{subheading}</p>}
        </SectionProse>
      )}
      <SectionActions>
        {
          ctaButtons?.map((btn, i) => (
            <Button
              variant={i === 0 ? 'default' : 'outline'}
              href={btn.url}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(btn.text)}
            >
              {btn.text}
            </Button>
          ))
        }
      </SectionActions>
      <SectionSplit class="gap-8">
        {
          (items ?? []).map(({ title, description, list }, i) => (
            <Tile class="items-stretch gap-4">
              <div class="flex items-center gap-3">
                <TileMedia variant="icon" class="size-10 text-base font-semibold">{i + 1}</TileMedia>
                <div class="h-px flex-1 bg-border"></div>
              </div>
              <TileContent class="p-0">
                <TileTitle class="not-first:mt-2">{title}</TileTitle>
                <TileDescription>{description}</TileDescription>
                <List class="text-foreground not-first:mt-4">
                  {list?.map((item) => (
                    <ListItem>
                      <CircleCheck />
                      {item}
                    </ListItem>
                  ))}
                </List>
              </TileContent>
            </Tile>
          ))
        }
      </SectionSplit>
    </SectionContent>
  </Section>
)}

{cleanVariant === 'split' && (
  <Section>
    <SectionSplit>
      <SectionContent>
        {(heading || subheading) && (
          <SectionProse>
            {heading && <h2>{heading}</h2>}
            {subheading && <p>{subheading}</p>}
          </SectionProse>
        )}
        <SectionActions>
          {
            ctaButtons?.map((btn, i) => (
              <Button
                variant={i === 0 ? 'default' : 'outline'}
                href={btn.url}
                data-gtm-category="cta"
                data-gtm-action="click"
                data-gtm-label={stegaClean(btn.text)}
              >
                {btn.text}
              </Button>
            ))
          }
        </SectionActions>
      </SectionContent>
      <SectionGrid>
        {
          (items ?? []).map(({ title, description, list }, i) => (
            <Tile>
              <TileMedia variant="icon">{i + 1}</TileMedia>
              <TileContent>
                <TileTitle>{title}</TileTitle>
                <TileDescription>{description}</TileDescription>
                <List class="text-foreground">
                  {list?.map((item) => (
                    <ListItem>
                      <CircleCheck />
                      {item}
                    </ListItem>
                  ))}
                </List>
              </TileContent>
            </Tile>
          ))
        }
      </SectionGrid>
    </SectionSplit>
  </Section>
)}

{cleanVariant === 'spread' && (
  <Section>
    <SectionContent>
      {(heading || subheading) && (
        <SectionProse>
          {heading && <h2>{heading}</h2>}
          {subheading && <p>{subheading}</p>}
        </SectionProse>
      )}
      <SectionActions>
        {
          ctaButtons?.map((btn, i) => (
            <Button
              variant={i === 0 ? 'default' : 'outline'}
              href={btn.url}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(btn.text)}
            >
              {btn.text}
            </Button>
          ))
        }
      </SectionActions>
    </SectionContent>
    <SectionSpread>
      {
        (items ?? []).map(({ title, description, list }, i) => (
          <Tile>
            <TileMedia variant="icon">{i + 1}</TileMedia>
            <TileContent>
              <TileTitle>{title}</TileTitle>
              <TileDescription>{description}</TileDescription>
              <List class="text-foreground">
                {list?.map((item) => (
                  <ListItem>
                    <CircleCheck />
                    {item}
                  </ListItem>
                ))}
              </List>
            </TileContent>
          </Tile>
        ))
      }
    </SectionSpread>
  </Section>
)}
