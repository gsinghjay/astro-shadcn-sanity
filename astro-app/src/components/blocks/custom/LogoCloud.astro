---
import type { LogoCloudBlock } from '@/lib/types';
import type { Sponsor } from '@/lib/sanity';
import { Section, SectionContent } from '@/components/ui/section';
import { Marquee, MarqueeContent } from '@/components/ui/marquee';
import { stegaClean } from '@sanity/client/stega';
import { safeUrlFor } from '@/lib/image';

interface Props extends Omit<LogoCloudBlock, 'sponsors'> {
  sponsors?: Sponsor[];
  class?: string;
  id?: string;
}

const { heading, sponsors, variant: rawVariant, class: className, id } = Astro.props;
const cleanVariant = (() => {
  const v = stegaClean(rawVariant);
  return v === 'marquee' || v === 'flex-wrap' || v === 'tiered' || v === 'grid-prominent' ? v : 'grid';
})();

const tierOrder = ['platinum', 'gold', 'silver', 'bronze'];
const tierLabels: Record<string, string> = {
  platinum: 'PLATINUM PARTNERS',
  gold: 'GOLD PARTNERS',
  silver: 'SILVER PARTNERS',
  bronze: 'BRONZE PARTNERS',
};

function groupByTier(list: Sponsor[]) {
  const groups = new Map<string, Sponsor[]>();
  for (const s of list) {
    const t = stegaClean(s.tier) || 'silver';
    if (!groups.has(t)) groups.set(t, []);
    groups.get(t)!.push(s);
  }
  return tierOrder.filter(t => groups.has(t)).map(t => ({ tier: t, sponsors: groups.get(t)! }));
}
---

{cleanVariant === 'grid' && (
  <Section size="sm" class:list={["bg-muted border-y border-border", className]} id={id} data-animate>
    {heading && (
      <div class="text-center">
        <h2 class="label-caps text-muted-foreground">{heading}</h2>
      </div>
    )}

    <ul class="grid grid-cols-[repeat(auto-fit,minmax(120px,1fr))] gap-px list-none">
      {sponsors?.map((sponsor) => {
        const logoUrl = safeUrlFor(sponsor.logo)?.width(120).url() ?? null;
        const content = (
          <div class="bg-muted p-6 flex items-center justify-center h-24">
            {logoUrl ? (
              <img src={logoUrl} alt={stegaClean(sponsor.name)} class="w-[120px] h-10 object-contain opacity-60 hover:opacity-100 transition-opacity" width="120" height="40" loading="lazy" />
            ) : (
              <span class="text-sm font-bold text-muted-foreground text-center leading-tight tracking-tight">{sponsor.name}</span>
            )}
          </div>
        );

        return (
          <li>
            {sponsor.website ? (
              <a href={stegaClean(sponsor.website)} target="_blank" rel="noopener" title={stegaClean(sponsor.name)}>
                {content}
              </a>
            ) : (
              content
            )}
          </li>
        );
      })}
    </ul>
  </Section>
)}

{cleanVariant === 'marquee' && (
  <Section class:list={["bg-foreground text-background", className]} id={id} data-animate>
    {heading && (
      <SectionContent class="items-center text-center">
        <span class="label-caps text-background/60">{heading}</span>
      </SectionContent>
    )}
    {sponsors && sponsors.length > 0 && (
      <>
        {(['left', 'right'] as const).map((direction) => (
          <Marquee>
            <MarqueeContent direction={direction} pauseOnHover>
              {sponsors.map((sponsor) => {
                const logoUrl = safeUrlFor(sponsor.logo)?.width(160).url() ?? null;
                const item = (
                  <div class="flex items-center justify-center px-8 h-20">
                    {logoUrl ? (
                      <img src={logoUrl} alt={stegaClean(sponsor.name)} class="w-[160px] h-14 object-contain opacity-70 hover:opacity-100 transition-opacity invert" width="160" height="60" loading="lazy" />
                    ) : (
                      <span class="text-base font-bold text-background/70 whitespace-nowrap">{sponsor.name}</span>
                    )}
                  </div>
                );
                return sponsor.website ? (
                  <a href={stegaClean(sponsor.website)} target="_blank" rel="noopener" title={stegaClean(sponsor.name)}>{item}</a>
                ) : item;
              })}
            </MarqueeContent>
          </Marquee>
        ))}
      </>
    )}
  </Section>
)}

{cleanVariant === 'tiered' && (
  <Section class={className} id={id} data-animate>
    {heading && (
      <SectionContent class="items-center text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}
    <SectionContent>
      {groupByTier(sponsors ?? []).map((group, i) => (
        <>
          {i > 0 && <hr class="border-border" />}
          <div class="space-y-4">
            <span class="label-caps text-muted-foreground">{tierLabels[group.tier] ?? group.tier.toUpperCase()}</span>
            <ul class="flex flex-wrap items-center gap-8 list-none">
              {group.sponsors.map((sponsor) => {
                const isPlatinum = stegaClean(sponsor.tier) === 'platinum';
                const w = isPlatinum ? 160 : 120;
                const logoUrl = safeUrlFor(sponsor.logo)?.width(w).url() ?? null;
                const item = (
                  <div class:list={["flex items-center justify-center", isPlatinum ? 'h-20' : 'h-14']}>
                    {logoUrl ? (
                      <img src={logoUrl} alt={stegaClean(sponsor.name)} class:list={["object-contain opacity-70 hover:opacity-100 transition-opacity", isPlatinum ? 'w-[160px] h-14' : 'w-[120px] h-10']} width={w} loading="lazy" />
                    ) : (
                      <span class:list={["font-bold text-muted-foreground", isPlatinum ? 'text-lg' : 'text-sm']}>{sponsor.name}</span>
                    )}
                  </div>
                );
                return (
                  <li>
                    {sponsor.website ? (
                      <a href={stegaClean(sponsor.website)} target="_blank" rel="noopener" title={stegaClean(sponsor.name)}>{item}</a>
                    ) : item}
                  </li>
                );
              })}
            </ul>
          </div>
        </>
      ))}
    </SectionContent>
  </Section>
)}

{cleanVariant === 'flex-wrap' && (
  <Section class={className} id={id} data-animate>
    {heading && (
      <SectionContent class="items-center text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}
    <ul class="flex flex-wrap justify-center gap-8 px-8 list-none">
      {sponsors?.map((sponsor) => {
        const logoUrl = safeUrlFor(sponsor.logo)?.width(160).url() ?? null;
        const content = (
          <div class="flex items-center justify-center h-20 px-4">
            {logoUrl ? (
              <img src={logoUrl} alt={stegaClean(sponsor.name)} class="w-[160px] h-12 object-contain opacity-60 hover:opacity-100 transition-opacity" width="160" height="60" loading="lazy" />
            ) : (
              <span class="text-sm font-bold text-muted-foreground whitespace-nowrap">{sponsor.name}</span>
            )}
          </div>
        );
        return (
          <li>
            {sponsor.website ? (
              <a href={stegaClean(sponsor.website)} target="_blank" rel="noopener" title={stegaClean(sponsor.name)}>{content}</a>
            ) : content}
          </li>
        );
      })}
    </ul>
  </Section>
)}

{cleanVariant === 'grid-prominent' && (
  <Section class={className} id={id} data-animate>
    {heading && (
      <SectionContent class="items-center text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}
    <ul class="grid grid-cols-[repeat(auto-fit,minmax(150px,1fr))] gap-px list-none">
      {(sponsors ?? []).map((sponsor) => {
        const tier = stegaClean(sponsor.tier) || 'silver';
        const isPlatinum = tier === 'platinum';
        const isGold = tier === 'gold';
        const w = isPlatinum ? 200 : isGold ? 160 : 120;
        const logoUrl = safeUrlFor(sponsor.logo)?.width(w).url() ?? null;
        const content = (
          <div class:list={[
            "bg-background p-6 flex items-center justify-center",
            isPlatinum && 'h-32',
            isGold && 'h-24',
            !isPlatinum && !isGold && 'h-20',
          ]}>
            {logoUrl ? (
              <img src={logoUrl} alt={stegaClean(sponsor.name)} class:list={["object-contain opacity-60 hover:opacity-100 transition-opacity", isPlatinum ? 'w-[200px] h-16' : isGold ? 'w-[160px] h-12' : 'w-[120px] h-8']} width={w} loading="lazy" />
            ) : (
              <span class:list={["font-bold text-muted-foreground text-center leading-tight", isPlatinum ? 'text-lg' : 'text-sm']}>{sponsor.name}</span>
            )}
          </div>
        );

        return (
          <li class:list={[isPlatinum && 'col-span-2']}>
            {sponsor.website ? (
              <a href={stegaClean(sponsor.website)} target="_blank" rel="noopener" title={stegaClean(sponsor.name)}>
                {content}
              </a>
            ) : (
              content
            )}
          </li>
        );
      })}
    </ul>
  </Section>
)}
