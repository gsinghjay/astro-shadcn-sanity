---
import { Section, SectionContent } from '@/components/ui/section';
import { stegaClean } from '@sanity/client/stega';
import { cn, blockBaseClasses } from '@/lib/utils';

interface Props {
  heading?: string;
  description?: string;
  items?: Array<{
    _key: string;
    title: string;
    content: string;
  }>;
  variant?: string;
  backgroundVariant?: string;
  spacing?: string;
  maxWidth?: string;
  class?: string;
  id?: string;
}

const { heading, description, items = [], variant: rawVariant, backgroundVariant, spacing, maxWidth, class: className, id } = Astro.props;
const cleanVariant = stegaClean(rawVariant) ?? 'default';
const baseClasses = blockBaseClasses(stegaClean(backgroundVariant), stegaClean(spacing), stegaClean(maxWidth));
---

{cleanVariant === 'default' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <div class="w-full max-w-3xl divide-y">
      {items.map((item) => (
        <details class="group">
          <summary class="flex cursor-pointer items-center justify-between py-4 text-left font-medium transition-colors hover:text-primary">
            {item.title}
            <span class="ml-4 flex-shrink-0 text-muted-foreground transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="pb-4 text-muted-foreground leading-relaxed">
            {item.content}
          </div>
        </details>
      ))}
    </div>
  </Section>
)}

{cleanVariant === 'bordered' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <div class="w-full max-w-3xl space-y-0">
      {items.map((item, i) => (
        <details class={cn('group border-x border-b', i === 0 && 'border-t')}>
          <summary class="flex cursor-pointer items-center justify-between p-4 text-left font-medium transition-colors hover:text-primary hover:bg-muted/50">
            {item.title}
            <span class="ml-4 flex-shrink-0 text-muted-foreground transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-4 pb-4 text-muted-foreground leading-relaxed">
            {item.content}
          </div>
        </details>
      ))}
    </div>
  </Section>
)}

{cleanVariant === 'separated' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <div class="w-full max-w-3xl space-y-3">
      {items.map((item) => (
        <details class="group border rounded-sm">
          <summary class="flex cursor-pointer items-center justify-between p-4 text-left font-medium transition-colors hover:text-primary hover:bg-muted/50">
            {item.title}
            <span class="ml-4 flex-shrink-0 text-muted-foreground transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-4 pb-4 text-muted-foreground leading-relaxed">
            {item.content}
          </div>
        </details>
      ))}
    </div>
  </Section>
)}
