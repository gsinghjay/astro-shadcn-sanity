---
import { Section, SectionContent, SectionGrid, SectionSplit, SectionMedia } from '@/components/ui/section';
import { Tile, TileContent, TileTitle, TileDescription } from '@/components/ui/tile';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { stegaClean } from '@sanity/client/stega';
import { cn } from '@/lib/utils';
import { safeUrlFor } from '@/lib/image';
import type { ProductShowcaseBlock } from '@/lib/types';
import { JsonLd } from '@/components/ui/json-ld';
import { extractNumericPrice } from '@/lib/structured-data';

interface Props extends ProductShowcaseBlock {
  class?: string;
  id?: string;
}

const { heading, description, products = [], variant: rawVariant, class: className, id } = Astro.props;
const rawCleaned = stegaClean(rawVariant);
const cleanVariant = rawCleaned === 'grid' || rawCleaned === 'featured' || rawCleaned === 'detail' ? rawCleaned : 'grid';

const productsJsonLd = products.filter(p => p.title).map(product => ({
  "@type": "Product",
  "name": stegaClean(product.title),
  ...(product.description && { "description": stegaClean(product.description) }),
  ...(product.image?.asset && { "image": safeUrlFor(product.image)?.width(800).url() }),
  ...(product.price && {
    "offers": {
      "@type": "Offer",
      "price": extractNumericPrice(stegaClean(product.price) || ''),
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
    },
  }),
  ...(product.link?.href && { "url": stegaClean(product.link.href) }),
}));
---

{productsJsonLd.length > 0 && productsJsonLd.map(p => <JsonLd schema={p} />)}

{cleanVariant === 'grid' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid>
      {products.map((product) => (
        <Tile variant="floating" href={product.link?.href}>
          <TileContent>
            <div class="aspect-video bg-muted rounded-sm overflow-hidden">
              {safeUrlFor(product.image) ? (
                <img src={safeUrlFor(product.image)!.width(600).height(338).fit('crop').url()} alt={product.image?.alt || stegaClean(product.title) || 'Product image'} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-muted-foreground text-sm">No image</div>
              )}
            </div>
            <div class="flex items-start justify-between gap-2">
              <TileTitle>{product.title}</TileTitle>
              {product.badge && <Badge>{product.badge}</Badge>}
            </div>
            {product.description && <TileDescription>{product.description}</TileDescription>}
            {product.price && (
              <span class="text-lg font-bold">{product.price}</span>
            )}
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'featured' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    {products.map((product, i) => (
      <SectionSplit class={i % 2 !== 0 ? '@lg:direction-rtl' : ''}>
        <SectionContent>
          <div class="flex items-center gap-3">
            <h3 class="text-2xl font-bold">{product.title}</h3>
            {product.badge && <Badge>{product.badge}</Badge>}
          </div>
          {product.description && (
            <p class="text-muted-foreground leading-relaxed">{product.description}</p>
          )}
          {product.price && (
            <span class="text-2xl font-bold">{product.price}</span>
          )}
          {product.link?.href && (
            <Button href={product.link.href} variant="outline">{product.link.label || 'Learn More'}</Button>
          )}
        </SectionContent>
        <SectionMedia>
          <div class="aspect-video bg-muted rounded-sm overflow-hidden">
            {safeUrlFor(product.image) ? (
              <img src={safeUrlFor(product.image)!.width(800).height(450).fit('crop').url()} alt={product.image?.alt || stegaClean(product.title) || 'Product image'} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-muted-foreground text-sm">No image</div>
            )}
          </div>
        </SectionMedia>
      </SectionSplit>
    ))}
  </Section>
)}

{cleanVariant === 'detail' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <div class="w-full space-y-8">
      {products.map((product) => (
        <Tile variant="floating" href={product.link?.href}>
          <TileContent class="flex-row gap-8">
            <div class="w-48 h-48 flex-shrink-0 bg-muted rounded-sm overflow-hidden">
              {safeUrlFor(product.image) ? (
                <img src={safeUrlFor(product.image)!.width(600).height(338).fit('crop').url()} alt={product.image?.alt || stegaClean(product.title) || 'Product image'} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-muted-foreground text-sm">No image</div>
              )}
            </div>
            <div class="flex-1 min-w-0 flex flex-col gap-2">
              <div class="flex items-start justify-between gap-2">
                <TileTitle class="text-xl">{product.title}</TileTitle>
                {product.badge && <Badge>{product.badge}</Badge>}
              </div>
              {product.description && <TileDescription>{product.description}</TileDescription>}
              {product.price && (
                <span class="text-lg font-bold mt-auto">{product.price}</span>
              )}
            </div>
          </TileContent>
        </Tile>
      ))}
    </div>
  </Section>
)}
