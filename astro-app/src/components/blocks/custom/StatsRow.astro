---
import type { StatsRowBlock } from '@/lib/types';
import { Section, SectionSplit, SectionGrid, SectionSpread, SectionContent } from '@/components/ui/section';
import { Marquee, MarqueeContent } from '@/components/ui/marquee';
import { stegaClean } from '@sanity/client/stega';
import { Tile, TileContent, TileDescription, TileTitle } from '@/components/ui/tile';
import { bgClasses } from '@/lib/utils';

interface Props extends StatsRowBlock {
  class?: string;
  id?: string;
}

const { heading, stats, backgroundVariant, variant } = Astro.props;
const bgVariant = stegaClean(backgroundVariant) ?? 'light';
const isDark = ['dark', 'hatched', 'primary', 'blueprint', 'mono'].includes(bgVariant);
const sectionBg = bgClasses[bgVariant] ?? '';
const gridBorderClass = isDark ? 'border-foreground' : 'border-border';

const rawVariant = stegaClean(variant);
const cleanVariant = rawVariant === 'grid' || rawVariant === 'split' || rawVariant === 'spread' || rawVariant === 'brutalist' || rawVariant === 'ticker' ? rawVariant : 'grid';
---

{cleanVariant === 'grid' && (
  <Section
    size="sm"
    class={`border-y ${sectionBg || 'bg-muted'} ${gridBorderClass}`}
    data-animate
  >
    {heading && (
      <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em] text-center mb-8">{heading}</h2>
    )}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {(stats ?? []).map((stat) => (
        <div class="text-center">
          <div class="text-4xl md:text-6xl font-bold tracking-[-0.04em] leading-none mb-3">
            {stat.value}
          </div>
          <div class={`label-caps ${isDark ? 'text-background/40' : 'text-muted-foreground'}`}>
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </Section>
)}

{cleanVariant === 'split' && (
  <Section class={sectionBg} data-animate>
    <SectionSplit>
      <SectionContent>
        {heading && (
          <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em]">{heading}</h2>
        )}
      </SectionContent>
      <SectionGrid class="grid-cols-1">
        {(stats ?? []).map((stat) => (
          <Tile>
            <TileContent>
              <TileTitle>{stat.value}</TileTitle>
              <TileDescription>{stat.label}</TileDescription>
            </TileContent>
          </Tile>
        ))}
      </SectionGrid>
    </SectionSplit>
  </Section>
)}

{cleanVariant === 'spread' && (
  <Section class={sectionBg} data-animate>
    <SectionContent>
      {heading && (
        <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em]">{heading}</h2>
      )}
    </SectionContent>
    <SectionSpread>
      {(stats ?? []).map((stat) => (
        <Tile>
          <TileContent>
            <TileTitle>{stat.value}</TileTitle>
            <TileDescription>{stat.label}</TileDescription>
          </TileContent>
        </Tile>
      ))}
    </SectionSpread>
  </Section>
)}

{cleanVariant === 'brutalist' && (
  <Section
    size="sm"
    class={`border-y ${sectionBg || 'bg-foreground text-background'} ${gridBorderClass}`}
    data-animate
  >
    {heading && (
      <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em] text-center mb-8">{heading}</h2>
    )}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {(stats ?? []).map((stat) => (
        <div class="border-t-4 border-primary pt-4">
          <div class="font-mono tabular-nums text-5xl md:text-6xl lg:text-7xl font-bold tracking-[-0.04em] leading-none mb-3">
            {stat.value}
          </div>
          <div class={`label-caps ${isDark ? 'text-background/40' : 'text-muted-foreground'}`}>
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </Section>
)}

{cleanVariant === 'ticker' && (
  <Section
    size="sm"
    class={`border-y ${sectionBg || 'bg-foreground text-background'} ${gridBorderClass} overflow-hidden`}
    data-animate
  >
    <Marquee>
      <MarqueeContent pauseOnHover>
        {(stats ?? []).map((stat) => (
          <div class="flex items-baseline gap-3 px-8 md:px-12 shrink-0">
            <span class="font-mono tabular-nums text-4xl md:text-5xl font-bold tracking-[-0.04em] leading-none">
              {stat.value}
            </span>
            <span class={`label-caps ${isDark ? 'text-background/40' : 'text-muted-foreground'}`}>
              {stat.label}
            </span>
          </div>
        ))}
      </MarqueeContent>
    </Marquee>
  </Section>
)}
