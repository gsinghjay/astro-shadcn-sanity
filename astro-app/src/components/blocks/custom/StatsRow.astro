---
import type { StatsRowBlock } from '@/lib/types';
import { Section, SectionSplit, SectionGrid, SectionSpread, SectionContent } from '@/components/ui/section';
import { Marquee, MarqueeContent } from '@/components/ui/marquee';
import { stegaClean } from '@sanity/client/stega';
import { Tile, TileContent, TileDescription, TileTitle } from '@/components/ui/tile';
import { bgClasses } from '@/lib/utils';
import { JsonLd } from '@/components/ui/json-ld';
import { extractNumericValue, extractUnitText } from '@/lib/structured-data';

interface Props extends StatsRowBlock {
  class?: string;
  id?: string;
}

const { heading, stats, backgroundVariant, variant } = Astro.props;

const statsJsonLd = (stats ?? []).filter(s => s.value && s.label).map(stat => {
  const cleanValue = stegaClean(stat.value) || '';
  const unit = extractUnitText(cleanValue);
  return {
    "@type": "QuantitativeValue",
    "name": stegaClean(stat.label),
    "value": extractNumericValue(cleanValue),
    ...(unit && { "unitText": unit }),
    ...(stat.description && { "description": stegaClean(stat.description) }),
  };
});
const bgVariant = stegaClean(backgroundVariant) ?? 'light';
// Dark bg text handled globally by BlockWrapper [data-bg-theme="dark"] CSS override
const sectionBg = bgClasses[bgVariant] ?? '';

const rawVariant = stegaClean(variant);
const cleanVariant = rawVariant === 'grid' || rawVariant === 'split' || rawVariant === 'spread' || rawVariant === 'brutalist' || rawVariant === 'ticker' ? rawVariant : 'grid';

// Adaptive grid columns based on stat count
const statCount = (stats ?? []).length;
const gridColsClass = statCount <= 1 ? 'grid-cols-1'
  : statCount === 2 ? 'grid-cols-2'
  : statCount === 3 ? 'grid-cols-1 @sm:grid-cols-3'
  : 'grid-cols-2 @md:grid-cols-4';
---

{statsJsonLd.length > 0 && statsJsonLd.map(s => <JsonLd schema={s} />)}

{cleanVariant === 'grid' && (
  <Section
    size="sm"
    class={`border-y ${sectionBg || 'bg-muted'} border-border`}
    data-animate
  >
    {heading && (
      <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em] text-center mb-8">{heading}</h2>
    )}
    <div class:list={['grid gap-8 @sm:gap-10 @lg:gap-12', gridColsClass]}>
      {(stats ?? []).map((stat) => (
        <div class="text-center">
          <div class="text-4xl @sm:text-5xl @lg:text-6xl font-bold tracking-[-0.04em] leading-none mb-3">
            {stat.value}
          </div>
          <div class={`label-caps text-muted-foreground`}>
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </Section>
)}

{cleanVariant === 'split' && (
  <Section class={sectionBg} data-animate>
    <SectionSplit>
      <SectionContent>
        {heading && (
          <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em]">{heading}</h2>
        )}
      </SectionContent>
      <SectionGrid class="grid-cols-1">
        {(stats ?? []).map((stat) => (
          <Tile>
            <TileContent>
              <TileTitle>{stat.value}</TileTitle>
              <TileDescription>{stat.label}</TileDescription>
            </TileContent>
          </Tile>
        ))}
      </SectionGrid>
    </SectionSplit>
  </Section>
)}

{cleanVariant === 'spread' && (
  <Section class={sectionBg} data-animate>
    <SectionContent>
      {heading && (
        <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em]">{heading}</h2>
      )}
    </SectionContent>
    <SectionSpread>
      {(stats ?? []).map((stat) => (
        <Tile>
          <TileContent>
            <TileTitle>{stat.value}</TileTitle>
            <TileDescription>{stat.label}</TileDescription>
          </TileContent>
        </Tile>
      ))}
    </SectionSpread>
  </Section>
)}

{cleanVariant === 'brutalist' && (
  <Section
    size="sm"
    class={`border-y ${sectionBg || 'bg-foreground text-background'} border-border`}
    data-animate
  >
    {heading && (
      <h2 class="text-2xl md:text-3xl font-bold tracking-[-0.03em] text-center mb-8">{heading}</h2>
    )}
    <div class:list={['grid gap-8 @sm:gap-10 @lg:gap-12', gridColsClass]}>
      {(stats ?? []).map((stat) => (
        <div class="border-t-4 border-primary pt-4">
          <div class="font-mono tabular-nums text-5xl @md:text-7xl @lg:text-8xl font-bold tracking-[-0.04em] leading-none mb-3">
            {stat.value}
          </div>
          <div class={`label-caps text-muted-foreground`}>
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </Section>
)}

{cleanVariant === 'ticker' && stats && stats.length > 0 && (
  <Section
    size="sm"
    class={`border-y ${sectionBg || 'bg-foreground text-background'} border-border overflow-hidden`}
    data-animate
  >
    <Marquee>
      <MarqueeContent pauseOnHover>
        {stats.map((stat) => (
          <div class="flex items-baseline gap-3 px-8 md:px-12 shrink-0">
            <span class="font-mono tabular-nums text-4xl md:text-5xl font-bold tracking-[-0.04em] leading-none">
              {stat.value}
            </span>
            <span class={`label-caps text-muted-foreground`}>
              {stat.label}
            </span>
          </div>
        ))}
      </MarqueeContent>
    </Marquee>
  </Section>
)}
