---
import { Section, SectionContent, SectionGrid, SectionMasonry } from '@/components/ui/section';
import { Tile, TileContent, TileTitle, TileDescription } from '@/components/ui/tile';
import { Badge } from '@/components/ui/badge';
import { stegaClean } from '@sanity/client/stega';
import { cn } from '@/lib/utils';
import { safeUrlFor } from '@/lib/image';
import type { CardGridBlock } from '@/lib/types';

interface Props extends CardGridBlock {
  class?: string;
  id?: string;
}

const { heading, description, cards = [], variant: rawVariant, class: className, id } = Astro.props;
const rawCleaned = stegaClean(rawVariant);
const cleanVariant = rawCleaned === 'grid-2' || rawCleaned === 'grid-3' || rawCleaned === 'grid-4' || rawCleaned === 'masonry' || rawCleaned === 'brutalist' ? rawCleaned : 'grid-3';

const gridSizeMap: Record<string, 'sm' | 'default' | 'lg'> = {
  'grid-2': 'lg',
  'grid-3': 'default',
  'grid-4': 'sm',
};
---

{cleanVariant !== 'masonry' && cleanVariant !== 'brutalist' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid size={gridSizeMap[cleanVariant] ?? 'default'}>
      {cards.map((card) => (
        <Tile variant="floating" href={card.link?.href}>
          <TileContent>
            {safeUrlFor(card.image) && (
              <div class="aspect-video bg-muted rounded-sm overflow-hidden -mx-6 -mt-6 mb-2">
                <img src={safeUrlFor(card.image)!.width(600).height(338).fit('crop').url()} alt={stegaClean(card.image?.alt) || stegaClean(card.title) || 'Card image'} class="w-full h-full object-cover" loading="lazy" />
              </div>
            )}
            <div class="flex items-start justify-between gap-2">
              <TileTitle>{card.title}</TileTitle>
              {card.badge && <Badge>{card.badge}</Badge>}
            </div>
            {card.description && <TileDescription>{card.description}</TileDescription>}
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'masonry' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionMasonry>
      {cards.map((card) => (
        <Tile variant="floating" href={card.link?.href}>
          <TileContent>
            {safeUrlFor(card.image) && (
              <div class="bg-muted rounded-sm overflow-hidden -mx-6 -mt-6 mb-2">
                <img
                  src={safeUrlFor(card.image)!.width(600).url()}
                  alt={stegaClean(card.image?.alt) || stegaClean(card.title) || 'Card image'}
                  class="w-full object-cover"
                  loading="lazy"
                  width={600}
                  height={card.image?.asset?.metadata?.dimensions?.width ? Math.round(600 * card.image.asset.metadata.dimensions.height / card.image.asset.metadata.dimensions.width) : 400}
                />
              </div>
            )}
            <div class="flex items-start justify-between gap-2">
              <TileTitle>{card.title}</TileTitle>
              {card.badge && <Badge>{card.badge}</Badge>}
            </div>
            {card.description && <TileDescription>{card.description}</TileDescription>}
          </TileContent>
        </Tile>
      ))}
    </SectionMasonry>
  </Section>
)}

{cleanVariant === 'brutalist' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05] border-l-4 border-primary pl-6">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid size="default">
      {cards.map((card) => (
        <div class="border-2 border-border hover:border-primary transition-colors">
          <div class="h-1 bg-primary"></div>
          <div class="p-6 flex flex-col gap-3">
            {safeUrlFor(card.image) && (
              <div class="aspect-video bg-muted overflow-hidden -mx-6 -mt-6 mb-2">
                <img src={safeUrlFor(card.image)!.width(600).height(338).fit('crop').url()} alt={stegaClean(card.image?.alt) || stegaClean(card.title) || 'Card image'} class="w-full h-full object-cover" loading="lazy" />
              </div>
            )}
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-bold text-lg">{card.title}</h3>
              {card.badge && <Badge>{card.badge}</Badge>}
            </div>
            {card.description && <p class="text-sm text-muted-foreground">{card.description}</p>}
          </div>
        </div>
      ))}
    </SectionGrid>
  </Section>
)}
