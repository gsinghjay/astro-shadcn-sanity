---
import type { ImageGalleryBlock } from '@/lib/types';
import type { GalleryItem } from '@/lib/sanity';
import { stegaClean } from '@sanity/client/stega';
import GalleryGrid from './_partials/GalleryGrid.astro';

interface Props extends ImageGalleryBlock {
  class?: string;
  id?: string;
  /** When true, renders content without the Section/SectionContent wrapper (for embedding in a page's own Section) */
  bare?: boolean;
}

const { heading, description, images, variant: rawVariant, _key: blockKey, bare = false } = Astro.props;
const variant = (stegaClean(rawVariant) ?? 'grid') as 'grid' | 'masonry' | 'single';

// Normalize the page-builder block shape into the partial's GalleryItem[].
// `featured` and `year` are typed values (boolean / number) so they don't carry
// stega markers; `category` is a stega-encoded enum string and must be cleaned
// before it reaches data attributes / filter logic in GalleryGrid.
const items: GalleryItem[] = (images ?? []).map((entry) => ({
  _key: entry._key ?? '',
  image: entry.image as GalleryItem['image'],
  caption: entry.caption ?? null,
  featured: entry.featured ?? null,
  year: entry.year ?? null,
  category: stegaClean(entry.category) ?? null,
}));
---

<GalleryGrid
  items={items}
  variant={variant}
  heading={heading}
  description={description}
  bare={bare}
  idSuffix={blockKey}
/>
