---
import type { SanityEvent } from '@/lib/sanity';
import { Section, SectionContent } from '@/components/ui/section';
import EventCard from '@/components/EventCard.astro';
import { JsonLd } from '@/components/ui/json-ld';
import { stegaClean } from '@sanity/client/stega';

interface Props {
  heading?: string | null;
  eventStatus?: 'all' | 'upcoming' | 'past' | null;
  limit?: number | null;
  events?: SanityEvent[];
  class?: string;
  id?: string;
  [key: string]: unknown;
}

const { heading, events = [] } = Astro.props;

const eventsJsonLd = events.filter(e => e.title).map(e => ({
  "@type": "Event",
  "name": stegaClean(e.title),
  "startDate": e.date,
  ...(e.endDate && { "endDate": e.endDate }),
  ...(e.location && { "location": { "@type": "Place", "name": stegaClean(e.location) } }),
  ...(e.description && { "description": stegaClean(e.description) }),
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  ...(e.slug?.current && { "url": `${Astro.url.origin}/events/${e.slug.current}` }),
}));
---

{eventsJsonLd.length > 0 && eventsJsonLd.map(e => <JsonLd schema={e} />)}

<Section data-animate>
  {heading && (
    <SectionContent>
      <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
    </SectionContent>
  )}

  <SectionContent>
    {events.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {events.map((e) => (
          <EventCard event={e} />
        ))}
      </div>
    ) : (
      <p class="text-muted-foreground text-center py-8">No events to display.</p>
    )}
  </SectionContent>
</Section>
