---
import { Section, SectionContent, SectionGrid } from '@/components/ui/section';
import { Tile, TileContent } from '@/components/ui/tile';
import { stegaClean } from '@sanity/client/stega';
import { cn } from '@/lib/utils';
import type { MetricsDashboardBlock } from '@/lib/types';
import { JsonLd } from '@/components/ui/json-ld';
import { extractNumericValue, extractUnitText } from '@/lib/structured-data';

interface Props extends MetricsDashboardBlock {
  class?: string;
  id?: string;
}

const { heading, description, metrics = [], variant: rawVariant, class: className, id } = Astro.props;

const metricsJsonLd = metrics.filter(m => m.value && m.label).map(metric => {
  const cleanValue = stegaClean(metric.value) || '';
  const unit = extractUnitText(cleanValue);
  return {
    "@type": "QuantitativeValue",
    "name": stegaClean(metric.label),
    "value": extractNumericValue(cleanValue),
    ...(unit && { "unitText": unit }),
    ...(metric.change && { "description": `Change: ${stegaClean(metric.change)}` }),
  };
});
const rawCleaned = stegaClean(rawVariant);
const cleanVariant = rawCleaned === 'grid' || rawCleaned === 'row' || rawCleaned === 'card' || rawCleaned === 'terminal' || rawCleaned === 'brutalist-grid' ? rawCleaned : 'grid';

const trendColor = (trend?: string) => {
  const t = stegaClean(trend);
  if (t === 'up') return 'text-green-600';
  if (t === 'down') return 'text-red-600';
  return 'text-muted-foreground';
};

const trendArrow = (trend?: string) => {
  const t = stegaClean(trend);
  if (t === 'up') return '↑';
  if (t === 'down') return '↓';
  return '→';
};
---

{metricsJsonLd.length > 0 && metricsJsonLd.map(m => <JsonLd schema={m} />)}

{cleanVariant === 'grid' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid size="sm">
      {metrics.map((metric) => (
        <Tile variant="floating">
          <TileContent>
            {metric.icon && <span class="text-2xl">{metric.icon}</span>}
            <span class="text-sm text-muted-foreground">{metric.label}</span>
            <span class="text-3xl font-bold">{metric.value}</span>
            {metric.change && (
              <span class={cn('text-sm font-medium flex items-center gap-1', trendColor(metric.trend))}>
                <span>{trendArrow(metric.trend)}</span>
                {metric.change}
              </span>
            )}
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'row' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <div class="w-full flex flex-wrap items-center justify-center gap-8 md:gap-16">
      {metrics.map((metric) => (
        <div class="flex flex-col items-center text-center gap-1">
          {metric.icon && <span class="text-2xl">{metric.icon}</span>}
          <span class="text-4xl font-bold">{metric.value}</span>
          <span class="text-sm text-muted-foreground">{metric.label}</span>
          {metric.change && (
            <span class={cn('text-sm font-medium flex items-center gap-1', trendColor(metric.trend))}>
              <span>{trendArrow(metric.trend)}</span>
              {metric.change}
            </span>
          )}
        </div>
      ))}
    </div>
  </Section>
)}

{cleanVariant === 'card' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-muted-foreground">{description}</p>
      )}
    </SectionContent>

    <SectionGrid>
      {metrics.map((metric) => (
        <Tile variant="floating">
          <TileContent class="flex-row items-center gap-4">
            {metric.icon && (
              <div class="w-12 h-12 flex-shrink-0 flex items-center justify-center bg-primary/10 rounded-sm">
                <span class="text-2xl">{metric.icon}</span>
              </div>
            )}
            <div class="flex-1 min-w-0">
              <span class="text-sm text-muted-foreground">{metric.label}</span>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold">{metric.value}</span>
                {metric.change && (
                  <span class={cn('text-sm font-medium flex items-center gap-1', trendColor(metric.trend))}>
                    <span>{trendArrow(metric.trend)}</span>
                    {metric.change}
                  </span>
                )}
              </div>
            </div>
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'terminal' && (
  <Section class={cn('bg-mono text-white', className)} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-mono font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
      {description && (
        <p class="text-lg leading-relaxed text-gray-400 font-mono">{description}</p>
      )}
    </SectionContent>

    <SectionGrid size="sm">
      {metrics.map((metric) => {
        const t = stegaClean(metric.trend);
        const valueColor = t === 'up' ? 'text-green-500' : t === 'down' ? 'text-red-500' : 'text-white';
        return (
          <div class="p-4">
            <span class="font-mono text-xs text-gray-500 uppercase tracking-wider">{metric.label}</span>
            <div class="flex items-baseline gap-2 mt-1">
              <span class={cn('text-3xl font-bold font-mono', valueColor)}>{metric.value}</span>
            </div>
            {metric.change && (
              <span class={cn('text-sm font-mono flex items-center gap-1 mt-1', t === 'up' ? 'text-green-500' : t === 'down' ? 'text-red-500' : 'text-gray-500')}>
                <span>{trendArrow(metric.trend)}</span>
                {metric.change}
              </span>
            )}
          </div>
        );
      })}
    </SectionGrid>
  </Section>
)}

{cleanVariant === 'brutalist-grid' && (
  <Section class={className} id={id} data-animate>
    <SectionContent class="max-w-3xl">
      {heading && (
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      )}
    </SectionContent>

    <div class="grid grid-cols-2 @3xl:grid-cols-4 w-full">
      {metrics.map((metric) => {
        const t = stegaClean(metric.trend);
        const topBorderColor = t === 'up' ? 'border-t-green-600' : t === 'down' ? 'border-t-red-600' : 'border-t-gray-400';
        return (
          <div class={cn('border-brutal border-foreground/20 border-t-4 p-4', topBorderColor)}>
            <span class="text-3xl md:text-4xl font-bold block">{metric.value}</span>
            <span class="label-caps text-muted-foreground text-[10px] mt-1 block">{metric.label}</span>
            {metric.change && (
              <span class={cn('text-xs font-medium mt-2 block', t === 'up' ? 'text-green-600' : t === 'down' ? 'text-red-600' : 'text-muted-foreground')}>
                {trendArrow(metric.trend)} {metric.change}
              </span>
            )}
          </div>
        );
      })}
    </div>
  </Section>
)}
