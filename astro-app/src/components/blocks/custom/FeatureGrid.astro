---
import type { FeatureGridBlock } from '@/lib/types';
import { Section, SectionContent, SectionGrid, SectionSplit, SectionProse } from '@/components/ui/section';
import { Tile, TileContent, TileTitle, TileDescription, TileSplit, TileMedia } from '@/components/ui/tile';
import { stegaClean } from '@sanity/client/stega';

interface Props extends FeatureGridBlock {
  class?: string;
  id?: string;
}

const { heading, columns, items, variant } = Astro.props;

// Clean variant value and default to 'grid'
const cleanVariant = stegaClean(variant ?? 'grid');

// For grid variant, determine grid size based on columns
const cols = columns || 3;
const gridSize = cols === 2 ? 'lg' : cols === 4 ? 'sm' : 'default';
---

{cleanVariant === 'grid' ? (
  // Default grid variant - matches current behavior exactly
  <Section data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <SectionGrid size={gridSize}>
      {(items ?? []).map((feature, i) => (
        <Tile variant="floating">
          <TileContent>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center border-2 border-foreground group-hover/tile:bg-primary group-hover/tile:border-primary transition-colors duration-200">
                <span class="text-xs font-bold group-hover/tile:text-primary-foreground transition-colors duration-200">
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>
              <TileTitle>{feature.title}</TileTitle>
            </div>
            <TileDescription class="whitespace-pre-line">{feature.description}</TileDescription>
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
) : cleanVariant === 'grid-centered' ? (
  // Grid-centered variant - centered alignment
  <Section data-animate>
    {heading && (
      <SectionContent class="max-w-3xl text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <SectionGrid size={gridSize}>
      {(items ?? []).map((feature, i) => (
        <Tile variant="floating" class="text-center">
          <TileContent class="items-center">
            <div class="flex flex-col items-center gap-3 w-full">
              <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center border-2 border-foreground group-hover/tile:bg-primary group-hover/tile:border-primary transition-colors duration-200">
                <span class="text-xs font-bold group-hover/tile:text-primary-foreground transition-colors duration-200">
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>
              <TileTitle>{feature.title}</TileTitle>
            </div>
            <TileDescription class="whitespace-pre-line">{feature.description}</TileDescription>
          </TileContent>
        </Tile>
      ))}
    </SectionGrid>
  </Section>
) : cleanVariant === 'horizontal-cards' ? (
  // Horizontal-cards variant - image left, text right
  <Section data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <div class="space-y-6">
      {(items ?? []).map((feature, i) => (
        <Tile variant="floating">
          <TileSplit>
            <TileMedia>
              <div class="w-full h-full bg-muted flex items-center justify-center">
                <span class="text-sm text-muted-foreground">Image {i + 1}</span>
              </div>
            </TileMedia>
            <TileContent>
              <TileTitle>{feature.title}</TileTitle>
              <TileDescription class="whitespace-pre-line">{feature.description}</TileDescription>
            </TileContent>
          </TileSplit>
        </Tile>
      ))}
    </div>
  </Section>
) : cleanVariant === 'sidebar-grid' ? (
  // Sidebar-grid variant - sticky sidebar with grid
  <Section data-animate>
    <SectionSplit class="@5xl:grid-cols-[1fr_2fr]">
      <SectionContent class="@5xl:sticky @5xl:top-[calc(var(--section-py,2rem)+3rem)]">
        <SectionProse>
          {heading && (
            <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
          )}
        </SectionProse>
      </SectionContent>

      <SectionGrid size="lg">
        {(items ?? []).map((feature, i) => (
          <Tile variant="floating">
            <TileContent>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center border-2 border-foreground group-hover/tile:bg-primary group-hover/tile:border-primary transition-colors duration-200">
                  <span class="text-xs font-bold group-hover/tile:text-primary-foreground transition-colors duration-200">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                </div>
                <TileTitle>{feature.title}</TileTitle>
              </div>
              <TileDescription class="whitespace-pre-line">{feature.description}</TileDescription>
            </TileContent>
          </Tile>
        ))}
      </SectionGrid>
    </SectionSplit>
  </Section>
) : (
  // Stacked variant - single column with horizontal split
  <Section data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <div class="space-y-12 pt-12">
      {(items ?? []).map((feature, i) => (
        <div class={`${i > 0 ? 'pt-12 border-t' : ''}`}>
          <Tile>
            <TileSplit class="gap-8">
              <div class="flex flex-col items-start justify-center min-w-0">
                <TileTitle class="text-lg">{feature.title}</TileTitle>
              </div>
              <div class="flex flex-col items-start justify-center">
                <TileDescription class="whitespace-pre-line">{feature.description}</TileDescription>
              </div>
            </TileSplit>
          </Tile>
        </div>
      ))}
    </div>
  </Section>
)}
