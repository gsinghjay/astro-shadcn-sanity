---
import { Section, SectionContent } from '@/components/ui/section';
import { stegaClean } from '@sanity/client/stega';
import { cn } from '@/lib/utils';
import { validateEmbedUrl } from '@/lib/embed-allowlist';
import type { EmbedBlockBlock } from '@/lib/types';

interface Props extends EmbedBlockBlock {
  class?: string;
  id?: string;
}

const {
  heading,
  embedUrl: rawEmbedUrl = '',
  rawEmbedCode: rawRawEmbedCode = '',
  caption,
  variant: rawVariant,
  class: className,
  id,
} = Astro.props;
const rawCleaned = stegaClean(rawVariant);
const cleanVariant = rawCleaned === 'default' || rawCleaned === 'contained' || rawCleaned === 'full-width' ? rawCleaned : 'default';
const embedUrl = stegaClean(rawEmbedUrl) ?? '';
const cleanRawEmbedCode = stegaClean(rawRawEmbedCode) ?? '';
const safeEmbedUrl = validateEmbedUrl(embedUrl);
const iframeTitle = stegaClean(heading) || stegaClean(caption) || 'Embedded content';
const sandboxFlags = 'allow-scripts allow-popups allow-popups-to-escape-sandbox';
const placeholderText = embedUrl ? 'Embed URL not allowed' : 'No embed URL provided';
---

{cleanVariant === 'default' && (
  <Section class={className} id={id} data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <div class="w-full">
      {cleanRawEmbedCode ? (
        <div class="relative w-full overflow-hidden rounded-sm" style="aspect-ratio: 16/9">
          <iframe
            srcdoc={cleanRawEmbedCode}
            title={iframeTitle}
            class="absolute inset-0 w-full h-full border-0"
            loading="lazy"
            sandbox={sandboxFlags}
          ></iframe>
        </div>
      ) : safeEmbedUrl ? (
        <div class="relative w-full overflow-hidden rounded-sm" style="aspect-ratio: 16/9">
          <iframe
            src={safeEmbedUrl}
            title={iframeTitle}
            class="absolute inset-0 w-full h-full border-0"
            loading="lazy"
            sandbox={sandboxFlags}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      ) : (
        <div class="relative w-full overflow-hidden rounded-sm" style="aspect-ratio: 16/9">
          <div class="absolute inset-0 flex items-center justify-center bg-muted text-muted-foreground text-sm">{placeholderText}</div>
        </div>
      )}
      {caption && (
        <p class="mt-3 text-sm text-muted-foreground text-center">{caption}</p>
      )}
    </div>
  </Section>
)}

{cleanVariant === 'contained' && (
  <Section class={className} id={id} data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <div class="w-full max-w-3xl mx-auto">
      {cleanRawEmbedCode ? (
        <div class="relative w-full overflow-hidden rounded-sm" style="aspect-ratio: 16/9">
          <iframe
            srcdoc={cleanRawEmbedCode}
            title={iframeTitle}
            class="absolute inset-0 w-full h-full border-0"
            loading="lazy"
            sandbox={sandboxFlags}
          ></iframe>
        </div>
      ) : safeEmbedUrl ? (
        <div class="relative w-full overflow-hidden rounded-sm" style="aspect-ratio: 16/9">
          <iframe
            src={safeEmbedUrl}
            title={iframeTitle}
            class="absolute inset-0 w-full h-full border-0"
            loading="lazy"
            sandbox={sandboxFlags}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      ) : (
        <div class="relative w-full overflow-hidden rounded-sm" style="aspect-ratio: 16/9">
          <div class="absolute inset-0 flex items-center justify-center bg-muted text-muted-foreground text-sm">{placeholderText}</div>
        </div>
      )}
      {caption && (
        <p class="mt-3 text-sm text-muted-foreground text-center">{caption}</p>
      )}
    </div>
  </Section>
)}

{cleanVariant === 'full-width' && (
  <Section class={cn('max-w-none', className)} id={id} data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <div class="w-full">
      {cleanRawEmbedCode ? (
        <div class="relative w-full overflow-hidden" style="aspect-ratio: 16/9">
          <iframe
            srcdoc={cleanRawEmbedCode}
            title={iframeTitle}
            class="absolute inset-0 w-full h-full border-0"
            loading="lazy"
            sandbox={sandboxFlags}
          ></iframe>
        </div>
      ) : safeEmbedUrl ? (
        <div class="relative w-full overflow-hidden" style="aspect-ratio: 16/9">
          <iframe
            src={safeEmbedUrl}
            title={iframeTitle}
            class="absolute inset-0 w-full h-full border-0"
            loading="lazy"
            sandbox={sandboxFlags}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      ) : (
        <div class="relative w-full overflow-hidden" style="aspect-ratio: 16/9">
          <div class="absolute inset-0 flex items-center justify-center bg-muted text-muted-foreground text-sm">{placeholderText}</div>
        </div>
      )}
      {caption && (
        <p class="mt-3 text-sm text-muted-foreground text-center">{caption}</p>
      )}
    </div>
  </Section>
)}
