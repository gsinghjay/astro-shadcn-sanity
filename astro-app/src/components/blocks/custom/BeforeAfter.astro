---
import { Section, SectionContent, SectionSplit } from '@/components/ui/section';
import { Badge } from '@/components/ui/badge';
import { stegaClean } from '@sanity/client/stega';
import { cn, blockBaseClasses } from '@/lib/utils';

interface Props {
  heading?: string;
  beforeImage?: { url: string; alt?: string };
  afterImage?: { url: string; alt?: string };
  beforeLabel?: string;
  afterLabel?: string;
  caption?: string;
  variant?: string;
  backgroundVariant?: string;
  spacing?: string;
  maxWidth?: string;
  class?: string;
  id?: string;
}

const {
  heading,
  beforeImage,
  afterImage,
  beforeLabel = 'Before',
  afterLabel = 'After',
  caption,
  variant: rawVariant,
  backgroundVariant,
  spacing,
  maxWidth,
  class: className,
  id,
} = Astro.props;
const cleanVariant = stegaClean(rawVariant) ?? 'side-by-side';
const baseClasses = blockBaseClasses(stegaClean(backgroundVariant), stegaClean(spacing), stegaClean(maxWidth));
---

{cleanVariant === 'side-by-side' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <SectionSplit>
      <div class="relative">
        <Badge class="absolute top-3 left-3 z-10">{beforeLabel}</Badge>
        <div class="aspect-video bg-muted rounded-sm overflow-hidden">
          {beforeImage ? (
            <img src={beforeImage.url} alt={beforeImage.alt || beforeLabel} class="w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-muted-foreground">{beforeLabel}</div>
          )}
        </div>
      </div>

      <div class="relative">
        <Badge class="absolute top-3 left-3 z-10">{afterLabel}</Badge>
        <div class="aspect-video bg-muted rounded-sm overflow-hidden">
          {afterImage ? (
            <img src={afterImage.url} alt={afterImage.alt || afterLabel} class="w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-muted-foreground">{afterLabel}</div>
          )}
        </div>
      </div>
    </SectionSplit>

    {caption && (
      <p class="text-sm text-muted-foreground text-center w-full">{caption}</p>
    )}
  </Section>
)}

{cleanVariant === 'stacked' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <div class="w-full max-w-3xl mx-auto space-y-6">
      <div class="relative">
        <Badge class="absolute top-3 left-3 z-10">{beforeLabel}</Badge>
        <div class="aspect-video bg-muted rounded-sm overflow-hidden">
          {beforeImage ? (
            <img src={beforeImage.url} alt={beforeImage.alt || beforeLabel} class="w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-muted-foreground">{beforeLabel}</div>
          )}
        </div>
      </div>

      <div class="relative">
        <Badge class="absolute top-3 left-3 z-10">{afterLabel}</Badge>
        <div class="aspect-video bg-muted rounded-sm overflow-hidden">
          {afterImage ? (
            <img src={afterImage.url} alt={afterImage.alt || afterLabel} class="w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-muted-foreground">{afterLabel}</div>
          )}
        </div>
      </div>
    </div>

    {caption && (
      <p class="text-sm text-muted-foreground text-center w-full">{caption}</p>
    )}
  </Section>
)}

{cleanVariant === 'toggle' && (
  <Section class={cn(baseClasses, className)} id={id} data-animate>
    {heading && (
      <SectionContent class="max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.05]">{heading}</h2>
      </SectionContent>
    )}

    <SectionSplit>
      <div class="relative">
        <Badge class="absolute top-3 left-3 z-10">{beforeLabel}</Badge>
        <div class="aspect-video bg-muted rounded-sm overflow-hidden">
          {beforeImage ? (
            <img src={beforeImage.url} alt={beforeImage.alt || beforeLabel} class="w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-muted-foreground">{beforeLabel}</div>
          )}
        </div>
      </div>

      <div class="relative">
        <Badge class="absolute top-3 left-3 z-10">{afterLabel}</Badge>
        <div class="aspect-video bg-muted rounded-sm overflow-hidden">
          {afterImage ? (
            <img src={afterImage.url} alt={afterImage.alt || afterLabel} class="w-full h-full object-cover" loading="lazy" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-muted-foreground">{afterLabel}</div>
          )}
        </div>
      </div>
    </SectionSplit>

    {caption && (
      <p class="text-sm text-muted-foreground text-center w-full">{caption}</p>
    )}
  </Section>
)}
