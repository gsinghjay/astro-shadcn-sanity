---
import type { HeroBannerBlock } from '@/lib/types';
import { Section, SectionContent, SectionActions, SectionSplit, SectionSpread, SectionMedia } from '@/components/ui/section';
import { Button } from '@/components/ui/button';
import { stegaClean } from '@sanity/client/stega';
import { urlFor, lqipStyle } from '@/lib/image';
import { cn, bgClasses } from '@/lib/utils';

interface Props extends HeroBannerBlock {
  class?: string;
  id?: string;
}

const { heading, subheading, ctaButtons, backgroundImages, backgroundVariant, alignment, variant: rawVariant, class: className, id } = Astro.props;
const variant = stegaClean(rawVariant) ?? 'centered';
const isCentered = stegaClean(alignment) === 'center';
const hasCarousel = backgroundImages && backgroundImages.length > 0;
const firstImage = backgroundImages?.[0];

const bgVariant = stegaClean(backgroundVariant) ?? 'dark';
const heroBg = bgClasses[bgVariant] ?? 'bg-foreground text-background';
const isDarkHero = ['dark', 'hatched', 'primary', 'blueprint', 'mono'].includes(bgVariant);
const cardBg = bgVariant === 'hatched' ? 'bg-hatched' : 'bg-foreground';

const hasImage = !!firstImage?.asset;
const isPatternedBg = ['hatched', 'blueprint'].includes(bgVariant);
const invertHoverClass = 'bg-transparent border-background text-background hover:bg-background hover:text-foreground';
const overlayHoverClass = 'bg-transparent border-background text-background hover:bg-background/10 hover:text-background';
const outlineHoverClass = (hasImage || isPatternedBg) ? overlayHoverClass : invertHoverClass;

function buildSrcset(image: NonNullable<typeof firstImage>, baseWidth: number, baseHeight: number, widths: number[]) {
  return widths
    .map(w => {
      const h = Math.round(w * baseHeight / baseWidth);
      return `${urlFor(image).width(w).height(h).fit('crop').url()} ${w}w`;
    })
    .join(', ');
}
---

{/* CENTERED variant — identical to pre-variant output (AC #4) */}
{variant === 'centered' && (
  <Section size="lg" class={cn(heroBg, "overflow-hidden relative group", className)} id={id} data-animate>
    {hasCarousel && (
      <div class="hero-carousel absolute inset-0" data-slot="hero-carousel" data-carousel>
        {backgroundImages?.map((image, index) => {
          const lqip = image.asset?.metadata?.lqip;
          const optimizedUrl = image.asset
            ? urlFor(image).width(1920).height(1080).fit('crop').url()
            : '';
          const isFirst = index === 0;
          const srcset = image.asset ? buildSrcset(image, 1920, 1080, [640, 1024, 1280, 1920]) : undefined;
          return (
            <div
              class="hero-carousel-slide absolute inset-0 transition-opacity duration-1000"
              data-slide={index}
              data-state={isFirst ? 'active' : 'inactive'}
              style={lqipStyle(lqip)}
            >
              <img
                src={optimizedUrl}
                srcset={srcset}
                sizes="100vw"
                alt={image.alt || `Slide ${index + 1}`}
                width={1920}
                height={1080}
                loading="eager"
                fetchpriority={isFirst ? 'high' : undefined}
                decoding="async"
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-foreground/60"></div>
            </div>
          );
        })}
        <div class="hero-carousel-nav absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          {backgroundImages?.map((_, index) => (
            <button
              class="hero-carousel-dot h-2 transition-all duration-300"
              data-dot={index}
              data-state={index === 0 ? 'active' : 'inactive'}
              aria-label={`Go to slide ${index + 1}`}
            />
          ))}
        </div>
      </div>
    )}

    <SectionContent class={`relative z-10 ${isCentered ? 'items-center text-center' : ''} ${cardBg} p-8 md:p-12`}>
      <h1 class="text-5xl md:text-6xl font-bold leading-[0.95] tracking-[-0.04em]">
        {heading}
      </h1>

      {subheading && (
        <p class="text-lg md:text-xl leading-relaxed max-w-2xl">
          {subheading}
        </p>
      )}

      {ctaButtons && ctaButtons.length > 0 && (
        <SectionActions class={isCentered ? 'justify-center' : ''}>
          {ctaButtons.map((btn, i) => (
            <Button
              href={btn.url}
              variant={i === 0 ? 'default' : (btn.variant || 'outline')}
              class={i > 0 ? outlineHoverClass : ''}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(btn.text)}
            >
              {btn.text}
            </Button>
          ))}
        </SectionActions>
      )}
    </SectionContent>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-primary z-10"></div>
  </Section>
)}

{/* OVERLAY variant — carousel + text directly over dark overlay (no glass card) */}
{variant === 'overlay' && (
  <Section size="lg" class={cn(heroBg, "overflow-hidden relative group", className)} id={id} data-animate>
    {hasCarousel && (
      <div class="hero-carousel absolute inset-0" data-slot="hero-carousel" data-carousel>
        {backgroundImages?.map((image, index) => {
          const lqip = image.asset?.metadata?.lqip;
          const optimizedUrl = image.asset
            ? urlFor(image).width(1920).height(1080).fit('crop').url()
            : '';
          const isFirst = index === 0;
          const srcset = image.asset ? buildSrcset(image, 1920, 1080, [640, 1024, 1280, 1920]) : undefined;
          return (
            <div
              class="hero-carousel-slide absolute inset-0 transition-opacity duration-1000"
              data-slide={index}
              data-state={isFirst ? 'active' : 'inactive'}
              style={lqipStyle(lqip)}
            >
              <img
                src={optimizedUrl}
                srcset={srcset}
                sizes="100vw"
                alt={image.alt || `Slide ${index + 1}`}
                width={1920}
                height={1080}
                loading="eager"
                fetchpriority={isFirst ? 'high' : undefined}
                decoding="async"
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-foreground/60"></div>
            </div>
          );
        })}
        <div class="hero-carousel-nav absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          {backgroundImages?.map((_, index) => (
            <button
              class="hero-carousel-dot h-2 transition-all duration-300"
              data-dot={index}
              data-state={index === 0 ? 'active' : 'inactive'}
              aria-label={`Go to slide ${index + 1}`}
            />
          ))}
        </div>
      </div>
    )}

    <SectionContent class={`relative z-10 ${isCentered ? 'items-center text-center' : ''}`}>
      <h1 class="text-5xl md:text-6xl font-bold leading-[0.95] tracking-[-0.04em]">
        {heading}
      </h1>

      {subheading && (
        <p class="text-lg md:text-xl leading-relaxed max-w-2xl">
          {subheading}
        </p>
      )}

      {ctaButtons && ctaButtons.length > 0 && (
        <SectionActions class={isCentered ? 'justify-center' : ''}>
          {ctaButtons.map((btn, i) => (
            <Button
              href={btn.url}
              variant={i === 0 ? 'default' : (btn.variant || 'outline')}
              class={i > 0 ? outlineHoverClass : ''}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(btn.text)}
            >
              {btn.text}
            </Button>
          ))}
        </SectionActions>
      )}
    </SectionContent>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-primary z-10"></div>
  </Section>
)}

{/* SPLIT variant — text + buttons left, first image right */}
{variant === 'split' && (
  <Section size="lg" class={cn(heroBg, className)} id={id} data-animate>
    <SectionSplit>
      <SectionContent>
        <h1 class="text-4xl md:text-6xl font-bold leading-[0.95] tracking-[-0.04em]">
          {heading}
        </h1>

        {subheading && (
          <p class="text-lg md:text-xl leading-relaxed max-w-xl">
            {subheading}
          </p>
        )}

        {ctaButtons && ctaButtons.length > 0 && (
          <SectionActions>
            {ctaButtons.map((btn, i) => (
              <Button
                href={btn.url}
                variant={i === 0 ? 'default' : (btn.variant || 'outline')}
                class={i > 0 ? outlineHoverClass : ''}
                data-gtm-category="cta"
                data-gtm-action="click"
                data-gtm-label={stegaClean(btn.text)}
              >
                {btn.text}
              </Button>
            ))}
          </SectionActions>
        )}
      </SectionContent>

      {firstImage?.asset && (
        <SectionMedia>
          <img
            src={urlFor(firstImage).width(960).height(1080).fit('crop').url()}
            srcset={buildSrcset(firstImage, 960, 1080, [480, 640, 960])}
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt={firstImage.alt || ''}
            width={960}
            height={1080}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            style={firstImage.asset?.metadata?.lqip ? `background-image: url(${firstImage.asset.metadata.lqip}); background-size: cover;` : undefined}
          />
        </SectionMedia>
      )}
    </SectionSplit>
  </Section>
)}

{/* SPLIT-ASYMMETRIC variant — small text left, large image right (2fr:3fr) */}
{variant === 'split-asymmetric' && (
  <Section size="lg" class={cn(heroBg, className)} id={id} data-animate>
    <SectionSplit class="@5xl:grid-cols-[2fr_3fr]">
      <SectionContent>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-[0.95] tracking-[-0.04em]">
          {heading}
        </h1>

        {subheading && (
          <p class="text-lg md:text-xl leading-relaxed">
            {subheading}
          </p>
        )}

        {ctaButtons && ctaButtons.length > 0 && (
          <SectionActions>
            {ctaButtons.map((btn, i) => (
              <Button
                href={btn.url}
                variant={i === 0 ? 'default' : (btn.variant || 'outline')}
                class={i > 0 ? outlineHoverClass : ''}
                data-gtm-category="cta"
                data-gtm-action="click"
                data-gtm-label={stegaClean(btn.text)}
              >
                {btn.text}
              </Button>
            ))}
          </SectionActions>
        )}
      </SectionContent>

      {firstImage?.asset && (
        <SectionMedia>
          <img
            src={urlFor(firstImage).width(1200).height(1080).fit('crop').url()}
            srcset={buildSrcset(firstImage, 1200, 1080, [640, 960, 1200])}
            sizes="(max-width: 1024px) 100vw, 60vw"
            alt={firstImage.alt || ''}
            width={1200}
            height={1080}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            style={firstImage.asset?.metadata?.lqip ? `background-image: url(${firstImage.asset.metadata.lqip}); background-size: cover;` : undefined}
          />
        </SectionMedia>
      )}
    </SectionSplit>
  </Section>
)}

{/* SPLIT-BLEED variant — compact text left (1fr), edge-bleed image right (3fr) */}
{variant === 'split-bleed' && (
  <Section size="lg" class={cn(heroBg, className)} id={id} data-animate style="padding-inline-end: 0">
    <SectionSplit class="@5xl:grid-cols-[1fr_3fr] @5xl:items-center">
      <SectionContent>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold leading-[0.95] tracking-[-0.04em] text-balance">
          {heading}
        </h1>

        {subheading && (
          <p class="text-lg md:text-xl leading-relaxed text-balance">
            {subheading}
          </p>
        )}

        {ctaButtons && ctaButtons.length > 0 && (
          <SectionActions>
            {ctaButtons.map((btn, i) => (
              <Button
                href={btn.url}
                variant={i === 0 ? 'default' : (btn.variant || 'outline')}
                class={i > 0 ? outlineHoverClass : ''}
                size="lg"
                data-gtm-category="cta"
                data-gtm-action="click"
                data-gtm-label={stegaClean(btn.text)}
              >
                {btn.text}
              </Button>
            ))}
          </SectionActions>
        )}
      </SectionContent>

      {firstImage?.asset && (
        <SectionMedia class="rounded-r-none @5xl:-my-(--section-py)">
          <img
            src={urlFor(firstImage).width(1440).height(960).fit('crop').url()}
            srcset={buildSrcset(firstImage, 1440, 960, [640, 960, 1440])}
            sizes="(max-width: 1024px) 100vw, 75vw"
            alt={firstImage.alt || ''}
            width={1440}
            height={960}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            style={firstImage.asset?.metadata?.lqip ? `background-image: url(${firstImage.asset.metadata.lqip}); background-size: cover;` : undefined}
          />
        </SectionMedia>
      )}
    </SectionSplit>
  </Section>
)}

{/* SPREAD variant — text left, buttons right, first image as background */}
{variant === 'spread' && (
  <Section size="lg" class={cn(heroBg, "overflow-hidden relative", className)} id={id} data-animate>
    {firstImage?.asset && (
      <div class="absolute inset-0">
        <img
          src={urlFor(firstImage).width(1920).height(1080).fit('crop').url()}
          srcset={buildSrcset(firstImage, 1920, 1080, [640, 1024, 1280, 1920])}
          sizes="100vw"
          alt={firstImage.alt || ''}
          width={1920}
          height={1080}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="w-full h-full object-cover"
          style={firstImage.asset?.metadata?.lqip ? `background-image: url(${firstImage.asset.metadata.lqip}); background-size: cover;` : undefined}
        />
        <div class="absolute inset-0 bg-foreground/60"></div>
      </div>
    )}

    <SectionSpread class="relative z-10">
      <SectionContent>
        <h1 class="text-4xl md:text-6xl font-bold leading-[0.95] tracking-[-0.04em]">
          {heading}
        </h1>

        {subheading && (
          <p class="text-lg md:text-xl leading-relaxed max-w-xl">
            {subheading}
          </p>
        )}
      </SectionContent>

      {ctaButtons && ctaButtons.length > 0 && (
        <SectionActions>
          {ctaButtons.map((btn, i) => (
            <Button
              href={btn.url}
              variant={i === 0 ? 'default' : (btn.variant || 'outline')}
              class={i > 0 ? outlineHoverClass : ''}
              data-gtm-category="cta"
              data-gtm-action="click"
              data-gtm-label={stegaClean(btn.text)}
            >
              {btn.text}
            </Button>
          ))}
        </SectionActions>
      )}
    </SectionSpread>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-primary z-10"></div>
  </Section>
)}

{/* BRUTALIST variant — asymmetric left-aligned layout, oversized heading, monospace subheading, thick bottom border */}
{variant === 'brutalist' && (
  <Section size="lg" class={cn(heroBg, className)} id={id} data-animate>
    <SectionSplit class="@5xl:grid-cols-[3fr_2fr]">
      <SectionContent>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[0.9] tracking-[-0.04em] whitespace-pre-line">
          {heading}
        </h1>

        {subheading && (
          <p class="font-mono label-caps tracking-[0.15em] max-w-xl">
            {subheading}
          </p>
        )}

        {ctaButtons && ctaButtons.length > 0 && (
          <SectionActions>
            {ctaButtons.map((btn, i) => (
              <Button
                href={btn.url}
                variant={i === 0 ? 'default' : (btn.variant || 'outline')}
                class={i > 0 ? (isDarkHero ? outlineHoverClass : '') : ''}
                data-gtm-category="cta"
                data-gtm-action="click"
                data-gtm-label={stegaClean(btn.text)}
              >
                {btn.text}
              </Button>
            ))}
          </SectionActions>
        )}
      </SectionContent>

      <div class="hidden @5xl:block" />
    </SectionSplit>
    <div class="absolute bottom-0 left-0 right-0 h-1 bg-primary z-10"></div>
  </Section>
)}
