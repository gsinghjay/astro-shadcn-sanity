---
import type { RichTextBlock } from '@/lib/types';
import { Section, SectionProse } from '@/components/ui/section';
import { PortableText } from 'astro-portabletext';
import { portableTextComponents } from '@/components/portable-text';
import { stegaClean } from '@sanity/client/stega';

interface Props extends RichTextBlock {
  class?: string;
  id?: string;
}

const { content, variant } = Astro.props;

// Clean variant value, remap legacy names, and default to 'prose'
const LEGACY_VARIANT_MAP: Record<string, string> = { narrow: 'standard', wide: 'highlighted' };
const raw = stegaClean(variant ?? 'prose');
const cleanVariant = LEGACY_VARIANT_MAP[raw] ?? raw;
---

<Section data-animate>
  {cleanVariant === 'highlighted' ? (
    <SectionProse size="lg" class="max-w-none">
      {content && <PortableText value={content} components={portableTextComponents} />}
    </SectionProse>
  ) : cleanVariant === 'standard' ? (
    <SectionProse style="--section-width: 672px; max-width: var(--section-width);" class="w-full">
      {content && <PortableText value={content} components={portableTextComponents} />}
    </SectionProse>
  ) : cleanVariant === 'sidebar' ? (
    <SectionProse size="sm" class="border-l-2 border-muted pl-6">
      {content && <PortableText value={content} components={portableTextComponents} />}
    </SectionProse>
  ) : (
    <SectionProse>
      {content && <PortableText value={content} components={portableTextComponents} />}
    </SectionProse>
  )}
</Section>
