---
import type { PullquoteBlock } from '@/lib/types';
import { Section, SectionContent, SectionSplit } from '@/components/ui/section';
import { Avatar, AvatarImage, AvatarFallback } from '@/components/ui/avatar';
import { stegaClean } from '@sanity/client/stega';
import { safeUrlFor, lqipStyle } from '@/lib/image';

interface Props extends PullquoteBlock {
  class?: string;
  id?: string;
}

const { quote, attribution, role, image, variant: rawVariant } = Astro.props;
const variant = (() => {
  const v = stegaClean(rawVariant);
  return v === 'centered' || v === 'split' || v === 'sidebar' || v === 'brutalist' ? v : 'centered';
})();
const imgSrc = safeUrlFor(image)?.width(120).height(120).fit('crop').url() ?? null;
const lqip = image?.asset?.metadata?.lqip;
const initials = attribution?.split(' ').filter(Boolean).map(n => n[0]).join('').slice(0, 2) ?? '';
---

{variant === 'centered' && (
  <Section data-animate>
    <SectionContent class="items-center text-center max-w-4xl mx-auto">
      <div class="text-8xl text-primary font-serif leading-none select-none" aria-hidden="true">&ldquo;</div>
      <blockquote class="text-3xl md:text-4xl font-bold tracking-[-0.03em] leading-[1.1]">
        <p>{quote}</p>
        {attribution && (
          <footer class="flex items-center gap-3 mt-6 text-base font-normal tracking-normal leading-normal">
            {imgSrc && (
              <Avatar>
                <AvatarImage
                  src={imgSrc}
                  alt={stegaClean(image?.alt) || stegaClean(attribution) || 'Quote author'}
                  style={lqipStyle(lqip)}
                />
                <AvatarFallback>{initials}</AvatarFallback>
              </Avatar>
            )}
            <div class="text-muted-foreground">
              <cite class="not-italic font-medium text-foreground [[data-bg-theme=dark]_&]:text-background">{attribution}</cite>
              {role && <span class="block text-sm">{role}</span>}
            </div>
          </footer>
        )}
      </blockquote>
    </SectionContent>
  </Section>
)}

{variant === 'split' && (
  <Section data-animate>
    <blockquote>
      <SectionSplit>
        <SectionContent class="justify-center">
          <div class="text-8xl text-primary font-serif leading-none select-none" aria-hidden="true">&ldquo;</div>
          <p class="text-2xl md:text-3xl font-bold tracking-[-0.03em] leading-[1.1]">{quote}</p>
        </SectionContent>

        <SectionContent class="justify-center">
          {attribution && (
            <>
              {imgSrc && (
                <Avatar class="w-16 h-16">
                  <AvatarImage
                    src={imgSrc}
                    alt={stegaClean(image?.alt) || stegaClean(attribution) || 'Quote author'}
                    style={lqipStyle(lqip)}
                  />
                  <AvatarFallback>{initials}</AvatarFallback>
                </Avatar>
              )}
              <footer class="text-muted-foreground">
                <cite class="not-italic font-medium text-lg text-foreground [[data-bg-theme=dark]_&]:text-background">{attribution}</cite>
                {role && <span class="block text-sm">{role}</span>}
              </footer>
            </>
          )}
        </SectionContent>
      </SectionSplit>
    </blockquote>
  </Section>
)}

{variant === 'sidebar' && (
  <Section data-animate>
    <SectionContent class="max-w-2xl">
      <blockquote class="border-l-4 border-primary pl-6">
        <p class="text-xl font-bold tracking-[-0.03em] leading-[1.2]">
          {quote}
        </p>
        {attribution && (
          <footer class="text-muted-foreground mt-4">
            <cite class="not-italic font-medium text-foreground [[data-bg-theme=dark]_&]:text-background">{attribution}</cite>
            {role && <span class="block text-sm">{role}</span>}
          </footer>
        )}
      </blockquote>
    </SectionContent>
  </Section>
)}

{variant === 'brutalist' && (
  <Section data-animate>
    <SectionContent class="max-w-5xl mx-auto">
      <blockquote class="border-l-[8px] border-primary pl-8 py-4">
        <p class="text-4xl md:text-5xl font-bold tracking-[-0.03em] leading-[1.1]">
          {quote}
        </p>
        {attribution && (
          <footer class="mt-8 font-mono">
            <cite class="not-italic font-bold text-foreground [[data-bg-theme=dark]_&]:text-background">{attribution}</cite>
            {role && <span class="block text-sm text-muted-foreground mt-1">{role}</span>}
          </footer>
        )}
      </blockquote>
    </SectionContent>
  </Section>
)}
