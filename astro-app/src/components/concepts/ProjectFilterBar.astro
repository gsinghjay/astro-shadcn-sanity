---
/**
 * ProjectFilterBar — Swiss Style filter sidebar concept.
 *
 * Collapsible groups with counts, search input, clear-all action.
 * Structural borders, label-caps headings, no rounded corners.
 */

interface FilterItem {
  label: string;
  count: number;
}

interface Props {
  techFilters: FilterItem[];
  industryFilters: FilterItem[];
  activeTechCount?: number;
  activeIndustryCount?: number;
}

const {
  techFilters,
  industryFilters,
  activeTechCount = 0,
  activeIndustryCount = 0,
} = Astro.props;

const totalActive = activeTechCount + activeIndustryCount;
const hasActiveFilters = totalActive > 0;
---

<aside class="w-[280px] space-y-4">
  {/* Heading with active count */}
  <div class="flex items-center justify-between border-b border-border pb-3">
    <h2 class="label-caps">Filters</h2>
    {hasActiveFilters && (
      <span class="label-caps bg-primary text-primary-foreground px-2 py-0.5">
        {totalActive}
      </span>
    )}
  </div>

  {/* Search input */}
  <input
    type="text"
    placeholder="Search technologies..."
    class="w-full border border-border bg-background px-3 py-2 text-sm tracking-[-0.01em] placeholder:text-muted-foreground/50 focus:outline-none focus:border-foreground"
  />

  {/* Technology collapsible group */}
  <details class="group" open>
    <summary class="flex cursor-pointer items-center justify-between py-2 border-b border-border select-none">
      <span class="label-caps">Technology</span>
      {activeTechCount > 0 && (
        <span class="label-caps bg-primary text-primary-foreground px-2 py-0.5">
          {activeTechCount}
        </span>
      )}
    </summary>
    <div class="flex flex-wrap gap-2 pt-3 pb-1">
      {techFilters.map((filter) => (
        <button
          type="button"
          class="label-caps border border-border px-3 py-1 transition-colors hover:bg-muted hover:border-foreground"
        >
          {filter.label}
          <span class="text-muted-foreground ml-1">({filter.count})</span>
        </button>
      ))}
    </div>
  </details>

  {/* Industry collapsible group */}
  <details class="group" open>
    <summary class="flex cursor-pointer items-center justify-between py-2 border-b border-border select-none">
      <span class="label-caps">Industry</span>
      {activeIndustryCount > 0 && (
        <span class="label-caps bg-primary text-primary-foreground px-2 py-0.5">
          {activeIndustryCount}
        </span>
      )}
    </summary>
    <div class="flex flex-wrap gap-2 pt-3 pb-1">
      {industryFilters.map((filter) => (
        <button
          type="button"
          class="label-caps border border-border px-3 py-1 transition-colors hover:bg-muted hover:border-foreground"
        >
          {filter.label}
          <span class="text-muted-foreground ml-1">({filter.count})</span>
        </button>
      ))}
    </div>
  </details>

  {/* Clear all */}
  {hasActiveFilters && (
    <div class="border-t border-border pt-3">
      <button
        type="button"
        class="label-caps text-primary underline underline-offset-4 transition-colors hover:text-primary/80"
      >
        Clear all filters
      </button>
    </div>
  )}
</aside>
