---
/**
 * ProjectCardEnhanced — Swiss Style concept for projects listing redesign.
 *
 * Improvements over current ProjectCard:
 * - Colored status bar at top (4px, status-coded)
 * - Larger sponsor logo area (64x64) with industry label
 * - Tag truncation: max 3 tags + "+N more" using label-caps
 * - Sharp edges, no shadows, structural borders only
 */

interface Sponsor {
  name: string;
  logoUrl: string;
  industry: string;
}

interface Props {
  title: string;
  slug: string;
  status: 'active' | 'completed' | 'archived';
  sponsor: Sponsor | null;
  excerpt: string;
  semester: string;
  tags: string[];
}

const { title, slug, status, sponsor, excerpt, semester, tags } = Astro.props;

const statusBarColors: Record<string, string> = {
  active: 'bg-green-700',
  completed: 'bg-primary',
  archived: 'bg-muted-foreground',
};

const statusLabelStyles: Record<string, string> = {
  active: 'border-green-700 text-green-700',
  completed: 'border-primary text-primary',
  archived: 'border-border text-muted-foreground',
};

const maxVisibleTags = 3;
const visibleTags = tags.slice(0, maxVisibleTags);
const remainingCount = tags.length - maxVisibleTags;
---

<a
  href={`/projects/${slug}`}
  class="block no-underline text-inherit group"
>
  <div class="border border-border bg-card overflow-hidden transition-colors duration-150 hover:border-foreground h-full flex flex-col">
    {/* Status accent bar */}
    <div class={`h-1 w-full ${statusBarColors[status] || statusBarColors.active}`} />

    <div class="p-6 flex flex-col flex-1 gap-4">
      {/* Header: title + status label */}
      <div class="flex items-start justify-between gap-3">
        <h3 class="text-lg font-[750] tracking-[-0.03em] leading-[1.05] group-hover:text-primary transition-colors">
          {title}
        </h3>
        <span class={`label-caps shrink-0 border px-2 py-0.5 ${statusLabelStyles[status] || statusLabelStyles.active}`}>
          {status}
        </span>
      </div>

      {/* Sponsor area */}
      {sponsor && (
        <div class="flex items-center gap-3">
          <div class="w-16 h-16 bg-muted flex items-center justify-center shrink-0 border border-border overflow-hidden">
            {sponsor.logoUrl ? (
              <img
                src={sponsor.logoUrl}
                alt={`${sponsor.name} logo`}
                class="w-full h-full object-contain p-1"
                loading="lazy"
              />
            ) : (
              <span class="text-xl font-[750] text-muted-foreground">
                {sponsor.name ? sponsor.name.split(' ').filter(Boolean).map((w) => w[0]).join('').slice(0, 2) : '?'}
              </span>
            )}
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-[750] tracking-[-0.01em]">{sponsor.name}</span>
            <span class="label-caps text-muted-foreground mt-1">{sponsor.industry}</span>
          </div>
        </div>
      )}

      {/* Excerpt */}
      {excerpt && (
        <p class="text-sm text-muted-foreground leading-[1.5] tracking-[-0.01em] line-clamp-3">
          {excerpt}
        </p>
      )}

      {/* Semester */}
      {semester && (
        <p class="label-caps text-muted-foreground">{semester}</p>
      )}

      {/* Tags with truncation — label-caps style */}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-auto pt-2 border-t border-border">
          {visibleTags.map((tag) => (
            <span class="label-caps border border-border px-2 py-0.5 text-muted-foreground">
              {tag}
            </span>
          ))}
          {remainingCount > 0 && (
            <span class="label-caps bg-muted px-2 py-0.5 text-muted-foreground">
              +{remainingCount} more
            </span>
          )}
        </div>
      )}
    </div>
  </div>
</a>
