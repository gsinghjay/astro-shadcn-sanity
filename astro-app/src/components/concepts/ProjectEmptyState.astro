---
/**
 * ProjectEmptyState — Swiss Style empty/filtered state concept.
 *
 * Two variants: 'filtered' (no matching results) and 'empty' (no projects).
 * Minimal SVG icons, structural layout, label-caps CTA.
 */

interface Props {
  variant: 'filtered' | 'empty';
  activeFilterCount?: number;
}

const { variant, activeFilterCount = 0 } = Astro.props;

const isFiltered = variant === 'filtered';
const heading = isFiltered ? 'No matching projects' : 'No projects yet';
const description = isFiltered
  ? 'Try adjusting your filters to see more results.'
  : 'Projects will appear here once they are added.';
---

<div class="flex flex-col items-center justify-center py-16 text-center">
  {/* Icon — minimal line art, Swiss restraint */}
  <div class="mb-6 text-muted-foreground/40">
    {isFiltered ? (
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="square"
        stroke-linejoin="miter"
      >
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
        <line x1="8" y1="8" x2="14" y2="14" />
        <line x1="14" y1="8" x2="8" y2="14" />
      </svg>
    ) : (
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="square"
        stroke-linejoin="miter"
      >
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
      </svg>
    )}
  </div>

  {/* Heading */}
  <h3 class="text-lg font-[750] tracking-[-0.03em] leading-[1.05] text-foreground">{heading}</h3>

  {/* Description */}
  <p class="mt-2 max-w-sm text-sm text-muted-foreground tracking-[-0.01em] leading-[1.5]">{description}</p>

  {/* CTA for filtered variant */}
  {isFiltered && (
    <button
      type="button"
      class="mt-6 border-2 border-foreground px-4 py-2 label-caps transition-colors hover:bg-foreground hover:text-background"
    >
      Clear all filters
      {activeFilterCount > 0 && (
        <span class="text-muted-foreground ml-1">({activeFilterCount})</span>
      )}
    </button>
  )}
</div>
